# vim: ft=yaml
---
{{- $onePasswordApp := "" -}}
{{- if stat "/Applications/1Password.app" -}}
  {{- $onePasswordApp = "/Applications/1Password.app" -}}
{{- else if stat (joinPath .chezmoi.homeDir "Applications/1Password.app") -}}
  {{- $onePasswordApp = joinPath .chezmoi.homeDir "Applications/1Password.app" -}}
{{- end -}}
{{- $vault := "" -}}
{{- $sshKey := "" -}}
{{- $gitEmail := promptStringOnce . "git.email" "Git user email" -}}
{{- $gitName := promptStringOnce . "git.name" "Git user name" -}}
{{- if ne $onePasswordApp "" -}}
  {{- $vault = promptStringOnce . "onepassword.vault" "1Password vault name (e.g. Personal, Private)" -}}
  {{- $sshKey = promptStringOnce . "onepassword.ssh_signing_key" "SSH signing key (e.g. ssh-ed25519 AAAA...)" -}}
{{- end }}
sourceDir: ~/MeinCodex/Codebasis/github.com/neumachen/dotfiles
diff:
  command: nvim
  pager: ""
  args:
    - -d
    - "{{`{{ .Destination }}`}}"
    - "{{`{{ .Target }}`}}"
merge:
  command: nvim
  args:
    - -d
    - "{{`{{ .Destination }}`}}"
    - "{{`{{ .Source }}`}}"
    - "{{`{{ .Target }}`}}"
data:
  onepassword:
    vault: {{ $vault | quote }}
    ssh_signing_key: {{ $sshKey | quote }}
  git:
    email: {{ $gitEmail | quote }}
    name: {{ $gitName | quote }}
    profile: |
      [user]
        email = {{ $gitEmail }}
        name = {{ $gitName }}
{{- if ne $onePasswordApp "" }}
        signingKey = {{ $sshKey }}
      [gpg]
        format = ssh
      [gpg "ssh"]
        program = "{{ $onePasswordApp }}/Contents/MacOS/op-ssh-sign"
        allowedSignersFile = ~/.config/git/allowed_signers
      [commit]
        gpgsign = true
{{- end }}
    # Directory-specific git profiles
    # Example:
    #   profiles:
    #     - name: work
    #       gitdir: ~/work/
    #       email: work@example.com
    #       # name: Optional (inherits from git.name if omitted)
    #       # signingKey: Optional (inherits from onepassword.ssh_signing_key if omitted)
    profiles: []

