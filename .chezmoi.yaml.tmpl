# vim: ft=yaml
---
sourceDir: ~/MeinCodex/Codebasis/github.com/neumachen/dotfiles
diff:
  command: nvim
  args:
    - -d
    - "{{`{{ .Destination }}`}}"
    - "{{`{{ .Target }}`}}"
merge:
  command: nvim
  args:
    - -d
    - "{{`{{ .Destination }}`}}"
    - "{{`{{ .Source }}"
    - "{{ .Target }}`}}"
data:
  onepassword:
    vault: {{ promptStringOnce . "onepassword.vault" "1Password vault name (e.g. Personal, Private)" | quote }}
    ssh_signing_key: {{ promptStringOnce . "onepassword.ssh_signing_key" "SSH signing key (e.g. ssh-ed25519 AAAA...)" | quote }}
  git:
    profile: |
      [user]
        email = kareem@hepburn.info
        name = Kareem Hepburn
{{- if stat "/Applications/1Password.app/Contents/MacOS/op-ssh-sign" }}
        signingKey = {{ .onepassword.ssh_signing_key }}
      [gpg]
        format = ssh
      [gpg "ssh"]
        program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
      [commit]
        gpgsign = true
{{- end }}

  envvars: []
