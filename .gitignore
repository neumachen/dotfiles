# Obsidian vault content — managed at runtime, not tracked in git.
# Directories (akten/, zakki/, kadai/, assets/) are created by run_once_05-obsidian-vault-dirs.sh.tmpl.
# No .keep files or content should be tracked here.
# Exception: _bases/ subdirectories are tracked for Obsidian Bases (.base files).
MeinCodex/Notizen/Obsidian/Main/akten/*
!MeinCodex/Notizen/Obsidian/Main/akten/.gitkeep
!MeinCodex/Notizen/Obsidian/Main/akten/_bases/
MeinCodex/Notizen/Obsidian/Main/zakki/*
!MeinCodex/Notizen/Obsidian/Main/zakki/.gitkeep
!MeinCodex/Notizen/Obsidian/Main/zakki/_bases/
MeinCodex/Notizen/Obsidian/Main/kadai/*
!MeinCodex/Notizen/Obsidian/Main/kadai/.gitkeep
!MeinCodex/Notizen/Obsidian/Main/kadai/_bases/
MeinCodex/Notizen/Obsidian/Main/assets/

# Obsidian plugin compiled files — downloaded by Obsidian on first launch, not tracked in git
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/plugins/**/main.js
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/plugins/**/styles.css

# Obsidian runtime-generated state files — written by Obsidian at runtime
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/workspace.json
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/workspace-mobile.json
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/graph.json
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/starred.json
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/bookmarks.json

# Obsidian plugin runtime cache files
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/plugins/omnisearch/*.db
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/plugins/omnisearch/*-cache.*

.git-ignored/

# macOS Finder metadata
.DS_Store

# Aider/AiderDesk local session artifacts
.aider-desk/
.aider.input.history
.aider.tags.cache.v4/
.aider.chat.history.md

# Claude Code local settings
.claude/
