#!/usr/bin/env bash
# Regenerate dynamic zsh completions sourced from CLI tools.
#
# Each generator (`<tool> completion zsh`-style) runs once and its output is
# written atomically to ${ZDOTDIR:-$HOME/.config/zsh}/completions/_<name>.
# Tools not on PATH are silently skipped.
#
# Triggered automatically by the chezmoi run_onchange_after_ hook whenever
# this script's content changes. Run manually after upgrading any listed
# tool to refresh its completion.

set -u

ZSH_COMP_DIR="${ZDOTDIR:-$HOME/.config/zsh}/completions"
mkdir -p "$ZSH_COMP_DIR"

have() { command -v "$1" >/dev/null 2>&1; }

generate() {
  local name="$1"; shift
  local out="${ZSH_COMP_DIR}/${name}"
  local tmp="${out}.tmp.$$"
  if "$@" >"$tmp" 2>/dev/null && [[ -s "$tmp" ]]; then
    mv -f "$tmp" "$out"
    printf '  regenerated %s\n' "$out"
  else
    rm -f "$tmp"
    printf '  failed     %s (%s)\n' "$name" "$*" >&2
    return 1
  fi
}

have rustup               && generate _rustup  rustup completions zsh
have rustup && have cargo && generate _cargo   rustup completions zsh cargo
have chezmoi && generate _chezmoi chezmoi completion zsh
have op      && generate _op      op completion zsh
have mo      && generate _mo      mo completion zsh
have mole    && generate _mole    mole completion zsh
have codex   && generate _codex   codex completion zsh
have jira    && generate _jira    jira completion zsh
have jiratui && generate _jiratui jiratui completions zsh
have wezterm && generate _wezterm wezterm shell-completion --shell zsh
have aider   && generate _aider   aider --shell-completion zsh
have gh       && generate _gh       gh completion -s zsh
have helm     && generate _helm     helm completion zsh
have istioctl && generate _istioctl istioctl completion zsh
have k9s      && generate _k9s      k9s completion zsh
have kubectl  && generate _kubectl  kubectl completion zsh
have minikube && generate _minikube minikube completion zsh
have skaffold && generate _skaffold skaffold completion zsh

# Custom script completions (inline heredocs)
generate_inline() {
  local name="$1"
  local out="${ZSH_COMP_DIR}/${name}"
  cat > "$out"
  printf '  generated  %s\n' "$out"
}

have fz-brew && generate_inline _fz-brew <<'EOF'
#compdef fz-brew
_fz-brew() {
  local -a commands=(
    'install:Select one or more formulae to install'
    'uninstall:Select one or more installed formulae to uninstall'
    'update:Select one or more installed formulae to upgrade'
  )
  _describe -t commands 'fz-brew command' commands
}
_fz-brew "$@"
EOF

have fz-docker && generate_inline _fz-docker <<'EOF'
#compdef fz-docker
_fz-docker() {
  local -a commands=(
    'attach:Select a stopped container to start and attach to'
    'rm:Select one or more containers to remove'
    'image-rm:Select one or more images to remove'
    'stop:Select a running container to stop'
  )
  _describe -t commands 'fz-docker command' commands
}
_fz-docker "$@"
EOF

have dots && generate_inline _dots <<'EOF'
#compdef dots
_dots() {
  local -a commands=(
    'apply:Show diff and apply changes locally'
    'update:Pull updates and apply changes'
    'init:Initialize chezmoi (first-time setup)'
    'diff:Show pending changes'
    'status:Show chezmoi status'
    'verify:Verify dotfiles are up to date'
    'add:Add files to chezmoi'
    'edit:Edit a chezmoi-managed file'
    'cd:Change to chezmoi source directory'
  )
  local -a options=(
    '--noconfirm[Skip confirmation prompt]'
    '--yes[Skip confirmation prompt]'
    '--override[Override all safety checks]'
    '--no-force[Do not use --force flag]'
    '--no-keep-going[Do not use --keep-going flag]'
    '--no-recursive[Do not use --recursive flag]'
    '--force[Use --force flag]'
    '--keep-going[Use --keep-going flag]'
    '--recursive[Use --recursive flag]'
    '-h[Show help]'
    '--help[Show help]'
  )
  _arguments -s \
    '1:command:->commands' \
    '*:options:->options'
  
  case "$state" in
    commands)
      _describe -t commands 'dots command' commands
      ;;
    options)
      _describe -t options 'dots option' options
      ;;
  esac
}
_dots "$@"
EOF

# Pre-compile to .zwc so the first compinit doesn't pay the parse cost.
if have zsh; then
  zsh -fc "for f in ${ZSH_COMP_DIR}/_*(.); do zcompile -U \"\$f\" 2>/dev/null || true; done" || true
fi

exit 0
