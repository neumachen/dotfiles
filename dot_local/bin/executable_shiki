#!/usr/bin/env bash
# shiki: launch AiderDesk in a container with per-session persistent data
#
# Wraps AiderDesk in a container with persistent sessions, SSH agent forwarding
# for 1Password commit signing, and sensible mounts. The static container shape
# (build args, env, base volumes, port publish, network aliases) is declared in
# ~/.config/shiki/compose.yaml; this script handles the per-invocation parts
# (session naming, project dir resolution, SSH socket detection, session
# restore, runtime overlay generation) and shells out to `docker compose`.
#
# Usage:
#   shiki [wrapper-opts] [-- -e KEY=VAL -v HOST:CONT ...]
#
# Behavior:
#   • Args BEFORE `--` are wrapper options.
#   • Args AFTER  `--` are docker-style passthrough flags (-e/--env,
#     -v/--volume) merged into the per-session compose overlay.
#   • Git identity and signing config are injected via env vars.
#   • AiderDesk runs as a headless web server (detached).
#   • Use --rebuild to (re)build the local image from the Dockerfile,
#     pulling the latest upstream AiderDesk base image in the process.
#
# Session lifecycle:
#   • Session data lives at ~/.local/share/aider-desk/<session>/data
#     (and Claude Code home at ~/.local/share/aider-desk/<session>/claude).
#   • If a container exists (running or stopped), it is reused.
#   • If the container is gone but the data directory remains,
#     a new container is created pointing at the existing data.
#   • Multiple -d/--dir flags mount several directories into the container
#     and all are registered as AiderDesk projects.
#   • Specifying `-n <name>` without a random suffix allows
#     deterministic session restore after container removal.

set -Eeuo pipefail

# ---------- defaults ----------
DEFAULT_IMAGE="shiki:latest"
DEFAULT_AIDER_DESK_IMAGE="ghcr.io/hotovo/aider-desk:local"
# Compose project name is fixed so OrbStack auto-domains read as
# "<session>.shiki.orb.local". The session name itself becomes the compose
# service + container name.
PROJECT_NAME="shiki"
# DEFAULT_PORT is the IN-CONTAINER port AiderDesk listens on. The HOST port
# defaults to 0 (Docker picks a free ephemeral port) so multiple sessions
# can run concurrently without collisions; access is via OrbStack's
# <session>.shiki.orb.local domain (or the auto-assigned localhost port,
# reported on startup).
DEFAULT_PORT=24337
DEFAULT_HOST_PORT=0
DEFAULT_NETWORK_MODE="bridge"
DEFAULT_HOST_LOCALHOST_ALIAS="host.docker.internal"
DEFAULT_HOST_GATEWAY_ALIAS="gateway.docker.internal"

IMAGE="$DEFAULT_IMAGE"
UPSTREAM_IMAGE="${UPSTREAM_IMAGE:-$DEFAULT_AIDER_DESK_IMAGE}"
NETWORK_MODE="${SHIKI_NETWORK_MODE:-$DEFAULT_NETWORK_MODE}"
HOST_LOCALHOST_ALIAS="${SHIKI_HOST_LOCALHOST_ALIAS:-$DEFAULT_HOST_LOCALHOST_ALIAS}"
HOST_GATEWAY_ALIAS="${SHIKI_HOST_GATEWAY_ALIAS:-$DEFAULT_HOST_GATEWAY_ALIAS}"
PULL_IMAGE=0
REBUILD_IMAGE=0
UPDATE_EXTENSIONS=0
BUILD_USE_CACHE=0
BUILD_PULL=1
SESSION_NAME=""
HOST_PORT="$DEFAULT_HOST_PORT"
HOST_PORT_EXPLICIT=0  # set to 1 when user passes -p/--port
PROJECT_DIRS=()
EXTRA_ENV=()
EXTRA_VOLUMES=()
EXTENSIONS_VOLUME_SUFFIX="extensions"

SHIKI_ABOUT=$'Shiki — AiderDesk in a container with persistent sessions.\nThis tool wraps AiderDesk with SSH agent forwarding for 1Password commit\nsigning and sensible mounts for your project.'

die() {
  echo-fatal "$*" >&2
  exit 1
}

usage() {
  cat <<'USAGE'
Usage:
  shiki [wrapper-opts] [-- -e KEY=VAL -v HOST:CONT ...]

Wrapper options (before --):
  -n, --name         Session name; doubles as the compose service and
                     container name (default: basename of the first --dir).
                     Deterministic names allow restoring sessions even
                     after the container has been removed.
  -i, --image        Image to run (default: shiki:latest).
  -p, --port         Host port for AiderDesk UI (default: auto-assigned by
                     Docker — printed on startup). Pass an explicit port
                     here to pin it. Multiple concurrent sessions only
                     conflict if you pin them to the same port.
  -d, --dir          Project directory to mount (default: $PWD).
                     Accepts one or more directory arguments after the flag,
                     and may also be specified multiple times. All mounted
                     directories are registered as AiderDesk projects.
                     The first directory is used for session naming.
      --host-network Share the host network namespace so localhost inside the
                     container resolves to localhost on the host machine.
                     In this mode, -p/--port changes the in-container listen
                     port directly because Docker port publishing is skipped.
      --bridge-network
                     Use normal bridge networking (default).
      --pull         Pull the upstream AiderDesk base image,
                     then exit without starting a container.
      --rebuild[=mods]
                     Rebuild the local shiki image from the Dockerfile,
                     then exit without starting a container.
                     Defaults to: pull,no-cache
                     Supported modifiers: pull,no-pull,cache,no-cache
      --update-extensions
                     Recreate the per-session extensions volume from the current image,
                     then exit without starting a container.
      --about        Show a short description of Shiki.
  -h, --help         Show this help and exit.

Docker passthrough (after --):
  -e, --env KEY=VAL  Append an environment variable to the container.
                     May be repeated. Values containing spaces or shell
                     metacharacters should be quoted on the command line.
  -v, --volume HOST:CONT[:MODE]
                     Append a bind mount or named volume to the container.
                     May be repeated. MODE is the standard docker mode
                     suffix (e.g. `ro`, `rw`, `z`).
  For other docker-compose tweaks, point SHIKI_COMPOSE_EXTRA_FILES at a
  compose override file.

Required environment variables:
  GIT_USER_NAME      Git identity: user name.
  GIT_USER_EMAIL     Git identity: user email.

Optional environment variables:
  GIT_SIGNING_KEY    SSH public key for commit signing.
  GIT_SIGN_COMMITS   "true" (default when GIT_SIGNING_KEY is set) or "false".
  AIDER_DESK_EXTENSIONS_APPEND
                     Comma-separated extension IDs/URLs to append to defaults at build time.
  AIDER_DESK_EXTENSIONS_OVERRIDE
                     Comma-separated extension IDs/URLs that fully replace defaults at build time.
  SHIKI_DIR          Override the shiki bundle directory
                     (default: $XDG_CONFIG_HOME/shiki or ~/.config/shiki).
                     Must contain compose.yaml, shiki.Dockerfile, entrypoint.sh,
                     and install-aiderdesk-extensions.sh.
  SHIKI_COMPOSE_EXTRA_FILES
                     Colon-separated list of extra compose files merged after the
                     base + host-network override + runtime overlay.
  SHIKI_NETWORK_MODE
                     Container network mode: bridge (default) or host.
  SHIKI_HOST_LOCALHOST_ALIAS
                     Hostname inside the container that resolves to the host
                     machine in bridge mode (default: host.docker.internal).
  SHIKI_HOST_GATEWAY_ALIAS
                     Secondary hostname inside the container that resolves to
                     the host machine in bridge mode (default: gateway.docker.internal).

SSH agent forwarding (required for commit signing):
  Shiki auto-detects a usable SSH agent socket for the container.
  Preference order:
    1. /run/host-services/ssh-auth.sock (when available from the container runtime)
    2. $SSH_AUTH_SOCK from the host environment
    3. ~/.1password/agent.sock as a fallback

Mounts (automatic):
  Project dir(s)           → /projects/<subdir>  (one mount per supplied dir)
  ~/.local/share/aider-desk/<session>/data
                           → /app/state            (persistent data, survives container removal)
  ~/.local/share/aider-desk/<session>/claude
                           → /root/.claude         (per-session Claude Code home; conversations,
                                                    projects/, sessions/, todos/ — isolated per session)
  ~/.claude/settings.json  → /root/.claude/settings.json (ro)
                                                   (user-level Claude config, layered on top of the
                                                    per-session mount; chezmoi-managed on the host)
  Docker volume            → /root/.aider-desk/extensions
                           (extensions cache seeded from image on first run)
  ~/.config/aider-desk/<subdir>
                           → /root/.aider-desk/<subdir> (one bind per subdir:
                           agents, commands, hooks, prompts, rules, skills)
  ~/.config/aider/aider.conf.yml
                           → /root/.aider.conf.yml (aider config, read-only)
  ~/.codex/                → /root/.codex/         (Codex auth, auto-created/mounted)
  ~/.local/share/aider-desk/<session>/mise/config
                           → /root/.config/mise    (per-session mise config)
  ~/.local/share/aider-desk/<session>/mise/data
                           → /root/.local/share/mise (mise-installed toolchains)
  ~/.local/share/aider-desk/<session>/mise/cache
                           → /root/.cache/mise     (mise downloads cache)
  SSH agent socket         → auto-detected container path (when available)

Per-session mise:
  The container has ripgrep + bubblewrap + socat baked in for Claude SDK,
  plus a shiki-managed mise config (gh, jq, fzf, vim, delta) auto-installed
  on first start. To add language toolchains (Node, Go, Python, ...) for a
  session, exec in and run:
    docker exec -it <session> bash
    mise use node@24    # or whichever tool/version
  Tools install under /root/.local/share/mise/ (persisted on the host)
  and are available on subsequent container starts of the same session.
  Set SHIKI_SKIP_MISE_INSTALL=1 on the container to skip the entrypoint
  auto-install (debugging / fast restart).

Claude SDK sandbox inside Docker:
  Docker's default seccomp/AppArmor profiles block bubblewrap's
  unshare()/clone()-with-CLONE_NEWUSER call. The compose template grants
  the shiki service `seccomp=unconfined` + `apparmor=unconfined` so the
  strong nested sandbox works without the weaker-mode fallback. Sandboxing
  itself is enabled via "sandbox": { "enabled": true } in the host's
  chezmoi-managed ~/.claude/settings.json (bind-mounted read-only into
  each session at /root/.claude/settings.json).

Host localhost access:
  Bridge mode (default):
    New containers get host aliases so processes inside shiki can reach
    services bound to localhost on the host machine.
    Inside the container, use:
      host.docker.internal:<port>
    Shiki also adds gateway.docker.internal as a secondary alias when the
    Docker engine supports host-gateway mappings.

  Host network mode:
    Run shiki with --host-network (or set SHIKI_NETWORK_MODE=host).
    In this mode, localhost inside the container is the host machine's
    localhost, so services bound on the host are reachable directly via:
      localhost:<port>

Session restore:
  Data is stored on the host at ~/.local/share/aider-desk/<session>/data.
  If the container is removed, running shiki with the same -n <name>
  will create a new container that picks up the existing data.

Examples:
  shiki                                         # auto-named from project dir
  shiki -n my-project                           # deterministic name, restorable
  shiki -n my-project                           # same command restores the session
  shiki -p 8080
  shiki -d ~/code/my-app -n my-app
  shiki -d ~/code/app ~/code/lib -n my-app     # one -d, multiple dirs
  shiki -d ~/code/app -d ~/code/lib -n my-app  # repeated -d also works
  shiki --host-network                          # localhost in container = host localhost
  shiki --pull                                  # pull upstream base image only
  shiki --rebuild                               # rebuild image only (pull + no-cache)
  shiki --rebuild=cache                         # rebuild image only (pull + cache)
  shiki --rebuild=no-pull                       # rebuild image only (no-pull + no-cache)
  shiki --rebuild=cache,no-pull                 # rebuild image only (no-pull + cache)
  shiki -n my-session --update-extensions       # refresh extensions volume only
  shiki -n my-session --rebuild --update-extensions
                                                   # rebuild image and refresh extensions only
  shiki -- -e OPENAI_API_KEY="$OPENAI_API_KEY"  # extra env var
  shiki -- -e FOO=bar -v ~/data:/data:ro         # extra env + read-only bind
USAGE
}

have() { command -v "$1" >/dev/null 2>&1; }
lower() { tr '[:upper:]' '[:lower:]'; }

sanitize_docker_name() {
  local in="${1:-}" out
  out="$(printf '%s' "$in" | lower | tr -c 'a-z0-9._-' '-')"
  out="$(printf '%s' "$out" | sed -E 's/^[^a-z0-9]+//')"
  out="$(printf '%s' "$out" | sed -E 's/[-._]+$//')"
  [ -n "$out" ] || out="session"
  out="${out:0:128}"
  printf '%s\n' "$out"
}

make_default_session_name() {
  local base
  base="$(basename "$PROJECT_DIR" | sanitize_docker_name)"
  [ -n "$base" ] || base="workspace"
  printf '%s\n' "$base"
}

print_about() { printf '%s\n' "$SHIKI_ABOUT"; }

parse_docker_extras() {
  while [ $# -gt 0 ]; do
    case "$1" in
    -e | --env)
      [ $# -ge 2 ] || die "-e/--env requires a KEY=VALUE argument"
      [ "${2#*=}" != "$2" ] || die "-e/--env value must be KEY=VALUE (got: $2)"
      EXTRA_ENV+=("$2")
      shift 2
      ;;
    --env=*)
      _kv="${1#--env=}"
      [ "${_kv#*=}" != "$_kv" ] || die "--env=KEY=VALUE: value must be KEY=VALUE (got: $_kv)"
      EXTRA_ENV+=("$_kv")
      shift
      ;;
    -v | --volume)
      [ $# -ge 2 ] || die "-v/--volume requires a HOST:CONTAINER[:MODE] argument"
      [ "${2#*:}" != "$2" ] || die "-v/--volume value must be HOST:CONTAINER[:MODE] (got: $2)"
      EXTRA_VOLUMES+=("$2")
      shift 2
      ;;
    --volume=*)
      _v="${1#--volume=}"
      [ "${_v#*:}" != "$_v" ] || die "--volume=HOST:CONTAINER[:MODE]: missing colon (got: $_v)"
      EXTRA_VOLUMES+=("$_v")
      shift
      ;;
    *)
      die "Unsupported passthrough flag: $1 (supported: -e/--env KEY=VAL, -v/--volume HOST:CONT[:MODE]). For other compose tweaks, set SHIKI_COMPOSE_EXTRA_FILES."
      ;;
    esac
  done
}

parse_rebuild_modifiers() {
  local modifiers="${1:-}"
  local modifier
  local -a parts

  [ -n "$modifiers" ] || return 0

  IFS=',' read -ra parts <<<"$modifiers"
  for modifier in "${parts[@]}"; do
    modifier="$(printf '%s' "$modifier" | xargs)"
    [ -n "$modifier" ] || continue
    case "$modifier" in
    pull) BUILD_PULL=1 ;;
    no-pull) BUILD_PULL=0 ;;
    cache) BUILD_USE_CACHE=1 ;;
    no-cache) BUILD_USE_CACHE=0 ;;
    *) die "Unknown --rebuild modifier: $modifier (supported: pull,no-pull,cache,no-cache)" ;;
    esac
  done
}

# ---------- parse args ----------
parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
    --)
      shift
      parse_docker_extras "$@"
      return 0
      ;;
    -h | --help) usage; exit 0 ;;
    --about) print_about; exit 0 ;;
    -n | --name)
      [ $# -ge 2 ] || die "--name requires an argument"
      SESSION_NAME="$(sanitize_docker_name "$2")"
      shift 2
      ;;
    -i | --image)
      [ $# -ge 2 ] || die "--image requires an argument"
      IMAGE="$2"
      shift 2
      ;;
    -p | --port)
      [ $# -ge 2 ] || die "--port requires an argument"
      HOST_PORT="$2"
      HOST_PORT_EXPLICIT=1
      shift 2
      ;;
    -d | --dir)
      shift
      local added=0
      while [ $# -gt 0 ]; do
        case "$1" in
        -*) break ;;
        *)
          PROJECT_DIRS+=("$1")
          added=1
          shift
          ;;
        esac
      done
      [ "$added" -eq 1 ] || die "--dir requires at least one directory argument"
      ;;
    --host-network) NETWORK_MODE="host"; shift ;;
    --bridge-network) NETWORK_MODE="bridge"; shift ;;
    --pull) PULL_IMAGE=1; shift ;;
    --rebuild)
      REBUILD_IMAGE=1
      if [ $# -ge 2 ] && [ "${2#-}" = "$2" ]; then
        parse_rebuild_modifiers "$2"
        shift 2
      else
        shift
      fi
      ;;
    --rebuild=*)
      REBUILD_IMAGE=1
      parse_rebuild_modifiers "${1#--rebuild=}"
      shift
      ;;
    --update-extensions) UPDATE_EXTENSIONS=1; shift ;;
    *) die "Unknown option: $1" ;;
    esac
  done
}

parse_args "$@"

# ---------- preflight ----------
have docker || die "docker not found in PATH."
have git || die "git not found in PATH (needed to read host identity)."

: "${GIT_USER_NAME:=$(git config user.name 2>/dev/null || true)}"
: "${GIT_USER_EMAIL:=$(git config user.email 2>/dev/null || true)}"

[ -n "${GIT_USER_NAME:-}" ] || die "GIT_USER_NAME is not set and git config user.name is empty."
[ -n "${GIT_USER_EMAIL:-}" ] || die "GIT_USER_EMAIL is not set and git config user.email is empty."

case "$NETWORK_MODE" in
bridge | host) ;;
*) die "Invalid SHIKI_NETWORK_MODE/--network mode: ${NETWORK_MODE} (expected: bridge or host)" ;;
esac

# ---------- defaults for dirs ----------
if [ ${#PROJECT_DIRS[@]} -eq 0 ]; then
  PROJECT_DIRS=("$PWD")
fi

# Resolve and validate all project dirs; primary dir is first entry
PROJECT_DIRS_ABS=()
for _d in "${PROJECT_DIRS[@]}"; do
  _abs="$(cd "$_d" 2>/dev/null && pwd)" || die "Project directory does not exist: $_d"
  [ -d "$_abs" ] || die "Project directory does not exist: $_d"
  PROJECT_DIRS_ABS+=("$_abs")
done
PROJECT_DIR="${PROJECT_DIRS_ABS[0]}"

# ---------- paths ----------
AIDER_DESK_GLOBAL="${HOME}/.config/aider-desk"
AIDER_DESK_DATA_ROOT="${HOME}/.local/share/aider-desk"
AIDER_CONFIG="${HOME}/.config/aider/aider.conf.yml"
CODEX_AUTH_HOST_PATH="${CODEX_AUTH_HOST_PATH:-${HOME}/.codex}"
CODEX_AUTH_CONTAINER_PATH="${CODEX_AUTH_CONTAINER_PATH:-/root/.codex}"

SHIKI_DIR="${SHIKI_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/shiki}"
SHIKI_COMPOSE_TEMPLATE="${SHIKI_DIR}/compose.template.yaml"
SHIKI_COMPOSE_HOST_NETWORK_TEMPLATE="${SHIKI_DIR}/compose.host-network.template.yaml"
SHIKI_DOCKERFILE="${SHIKI_DIR}/shiki.Dockerfile"
SHIKI_ENTRYPOINT="${SHIKI_DIR}/entrypoint.sh"
SHIKI_EXTENSIONS_INSTALLER="${SHIKI_DIR}/install-aiderdesk-extensions.sh"

for _f in "$SHIKI_COMPOSE_TEMPLATE" "$SHIKI_COMPOSE_HOST_NETWORK_TEMPLATE" "$SHIKI_DOCKERFILE" "$SHIKI_ENTRYPOINT" "$SHIKI_EXTENSIONS_INSTALLER"; do
  [ -f "$_f" ] || die "Missing shiki bundle file: $_f (set SHIKI_DIR or sync your dotfiles)."
done

# ---------- SSH agent socket ----------
# Preference order:
#   1. Container runtime host-services socket, when available
#   2. Active host SSH_AUTH_SOCK
#   3. ~/.1password/agent.sock fallback
DEFAULT_1PASSWORD_SOCK="${HOME}/.1password/agent.sock"
HOST_SERVICES_SSH_AUTH_SOCK="/run/host-services/ssh-auth.sock"
HOST_SSH_AUTH_SOCK="${SSH_AUTH_SOCK:-$DEFAULT_1PASSWORD_SOCK}"
CONTAINER_SSH_AUTH_SOCK="/run/host-ssh-agent.sock"
USE_HOST_SERVICES_SSH_AUTH_SOCK=0

if docker run --rm -v "${HOST_SERVICES_SSH_AUTH_SOCK}:${HOST_SERVICES_SSH_AUTH_SOCK}" alpine sh -c 'test -S "$1"' -- "$HOST_SERVICES_SSH_AUTH_SOCK" >/dev/null 2>&1; then
  USE_HOST_SERVICES_SSH_AUTH_SOCK=1
  HOST_SSH_AUTH_SOCK="$HOST_SERVICES_SSH_AUTH_SOCK"
  CONTAINER_SSH_AUTH_SOCK="$HOST_SERVICES_SSH_AUTH_SOCK"
elif [ -n "${HOST_SSH_AUTH_SOCK:-}" ]; then
  # Resolve symlinks so Docker mounts the real socket path, not a symlink.
  if command -v realpath >/dev/null 2>&1; then
    HOST_SSH_AUTH_SOCK="$(realpath "$HOST_SSH_AUTH_SOCK" 2>/dev/null || printf '%s' "$HOST_SSH_AUTH_SOCK")"
  elif command -v readlink >/dev/null 2>&1; then
    HOST_SSH_AUTH_SOCK="$(readlink -f "$HOST_SSH_AUTH_SOCK" 2>/dev/null || printf '%s' "$HOST_SSH_AUTH_SOCK")"
  fi
fi

have_container_ssh_auth_sock() {
  if [ "${USE_HOST_SERVICES_SSH_AUTH_SOCK:-0}" -eq 1 ]; then
    return 0
  fi
  [ -n "${HOST_SSH_AUTH_SOCK:-}" ] && [ -S "${HOST_SSH_AUTH_SOCK}" ]
}

# ---------- signing key fallback ----------
if [ -z "${GIT_SIGNING_KEY:-}" ]; then
  host_gpg_format="$(git config gpg.format 2>/dev/null || true)"
  if [ "$host_gpg_format" = "ssh" ]; then
    : "${GIT_SIGNING_KEY:=$(git config user.signingkey 2>/dev/null || true)}"
  fi
fi

if [ -n "${GIT_SIGNING_KEY:-}" ] && ! have_container_ssh_auth_sock; then
  echo-warn "GIT_SIGNING_KEY is set but no usable SSH agent socket was found."
  echo-warn "  Checked: ${HOST_SSH_AUTH_SOCK:-<unset>}"
  echo-warn "  Commit signing will fail without agent forwarding."
fi

# ---------- container path collision handling ----------
# Each dir is mounted AS a named subdirectory inside /projects
# (e.g. host /home/user/a-1 → /projects/a-1). If basenames collide,
# append a numeric suffix to keep targets unique.
PROJECT_CONTAINER_PATHS=()
for _d in "${PROJECT_DIRS_ABS[@]}"; do
  _base="$(basename -- "$_d")"
  _name="$_base"
  _suffix=2
  while :; do
    _exists=0
    for _cp in "${PROJECT_CONTAINER_PATHS[@]}"; do
      if [ "$_cp" = "/projects/$_name" ]; then
        _exists=1
        break
      fi
    done
    [ "$_exists" -eq 0 ] && break
    _name="${_base}-${_suffix}"
    _suffix=$((_suffix + 1))
  done
  PROJECT_CONTAINER_PATHS+=("/projects/${_name}")
done

PROJECT_CONTAINER_PATH_LIST=""
for _cp in "${PROJECT_CONTAINER_PATHS[@]}"; do
  if [ -z "$PROJECT_CONTAINER_PATH_LIST" ]; then
    PROJECT_CONTAINER_PATH_LIST="$_cp"
  else
    PROJECT_CONTAINER_PATH_LIST="${PROJECT_CONTAINER_PATH_LIST}:${_cp}"
  fi
done

mkdir -p \
  "${AIDER_DESK_GLOBAL}/hooks" \
  "${AIDER_DESK_GLOBAL}/skills" \
  "${AIDER_DESK_GLOBAL}/agents" \
  "${AIDER_DESK_GLOBAL}/commands" \
  "${AIDER_DESK_GLOBAL}/prompts" \
  "${AIDER_DESK_GLOBAL}/rules" \
  "${CODEX_AUTH_HOST_PATH}"

# ---------- session resolution ----------
# 0 = new session, 1 = resume container (running or stopped), 2 = restore from data
SESSION_ACTION=0

if [ -z "$SESSION_NAME" ]; then
  SESSION_NAME="$(make_default_session_name)"
fi

if docker ps -a --format '{{.Names}}' | grep -qx "$SESSION_NAME"; then
  SESSION_ACTION=1
elif [ -d "${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/data" ]; then
  SESSION_ACTION=2
fi

SESSION_DATA="${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/data"
# Per-session Claude Code home (~/.claude inside the container).
# Persists conversation files at ~/.claude/projects/<cwd>/<session-id>.jsonl
# across container removal so resume-by-session-id keeps working.
SESSION_CLAUDE="${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/claude"
SESSION_RUNTIME_DIR="${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/runtime"
RUNTIME_OVERLAY="${SESSION_RUNTIME_DIR}/compose.runtime.yaml"
RENDERED_COMPOSE="${SESSION_RUNTIME_DIR}/compose.yaml"
RENDERED_COMPOSE_HOST_NETWORK="${SESSION_RUNTIME_DIR}/compose.host-network.yaml"
EXTENSIONS_VOLUME="${SESSION_NAME}-${EXTENSIONS_VOLUME_SUFFIX}"
SERVICE_NAME="$SESSION_NAME"

# Per-session mise dirs. Each session keeps its own toolchain installs so
# pinning differs per project. The container env (set in the Dockerfile)
# already points MISE_CONFIG_DIR/MISE_DATA_DIR/MISE_CACHE_DIR at these.
SESSION_MISE_CONFIG="${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/mise/config"
SESSION_MISE_DATA="${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/mise/data"
SESSION_MISE_CACHE="${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/mise/cache"

# Legacy-data migration hint: if a prior `shiki-<name>` data dir exists but
# the un-prefixed dir does not, refuse to start and tell the user how to
# migrate. (One-shot, deliberate opt-in — no silent rename of preserved data.)
LEGACY_DATA_DIR="${AIDER_DESK_DATA_ROOT}/shiki-${SESSION_NAME}/data"
if [ -d "$LEGACY_DATA_DIR" ] && [ ! -d "$SESSION_DATA" ]; then
  echo-warn "Legacy session data detected at ${AIDER_DESK_DATA_ROOT}/shiki-${SESSION_NAME}/."
  echo-warn "shiki now stores sessions without the 'shiki-' prefix. To migrate:"
  echo-warn "  docker rm -f shiki-${SESSION_NAME} 2>/dev/null || true"
  echo-warn "  docker volume rm shiki-${SESSION_NAME}-extensions 2>/dev/null || true"
  echo-warn "  mv ${AIDER_DESK_DATA_ROOT}/shiki-${SESSION_NAME} ${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}"
  echo-warn "Then re-run: shiki -n ${SESSION_NAME}"
  exit 1
fi

# ---------- env exports for docker compose ----------
export SHIKI_IMAGE="$IMAGE"
export SESSION_NAME
export UPSTREAM_IMAGE
export AIDER_DESK_EXTENSIONS_APPEND="${AIDER_DESK_EXTENSIONS_APPEND:-}"
export AIDER_DESK_EXTENSIONS_OVERRIDE="${AIDER_DESK_EXTENSIONS_OVERRIDE:-}"
export GIT_USER_NAME GIT_USER_EMAIL
export GIT_SIGNING_KEY="${GIT_SIGNING_KEY:-}"
export GIT_SIGN_COMMITS="${GIT_SIGN_COMMITS:-}"
export AIDER_DESK_PROJECTS="$PROJECT_CONTAINER_PATH_LIST"
export SHIKI_NETWORK_MODE="$NETWORK_MODE"
if [ "$NETWORK_MODE" = "host" ]; then
  export SHIKI_HOST_LOCALHOST="localhost"
  export SHIKI_HOST_GATEWAY="localhost"
else
  export SHIKI_HOST_LOCALHOST="$HOST_LOCALHOST_ALIAS"
  export SHIKI_HOST_GATEWAY="$HOST_GATEWAY_ALIAS"
fi
export SESSION_DATA SESSION_CLAUDE
# Host's user-level Claude Code config. The compose template layers
# ${CLAUDE_HOST}/settings.json on top of the per-session /root/.claude
# mount so chezmoi-managed permissions/model/env policy applies inside
# every session.
export CLAUDE_HOST="${HOME}/.claude"
export SESSION_MISE_CONFIG SESSION_MISE_DATA SESSION_MISE_CACHE
export AIDER_DESK_GLOBAL
export CODEX_AUTH_HOST_PATH CODEX_AUTH_CONTAINER_PATH
export EXTENSIONS_VOLUME
export HOST_PORT

# ---------- render compose templates ----------
# Compose can't interpolate mapping keys, so the service name is substituted
# into a private copy of each template here.
render_compose_templates() {
  mkdir -p "$SESSION_RUNTIME_DIR"
  sed "s/__SERVICE__:/${SERVICE_NAME}:/" "$SHIKI_COMPOSE_TEMPLATE" >"$RENDERED_COMPOSE"
  sed "s/__SERVICE__:/${SERVICE_NAME}:/" "$SHIKI_COMPOSE_HOST_NETWORK_TEMPLATE" >"$RENDERED_COMPOSE_HOST_NETWORK"
}
render_compose_templates

# ---------- compose command assembly ----------
compose_cmd=(
  docker compose
  --project-directory "$SHIKI_DIR"
  --project-name "$PROJECT_NAME"
  --env-file /dev/null
  -f "$RENDERED_COMPOSE"
)
if [ "$NETWORK_MODE" = "host" ]; then
  compose_cmd+=(-f "$RENDERED_COMPOSE_HOST_NETWORK")
fi
compose_cmd+=(-f "$RUNTIME_OVERLAY")

if [ -n "${SHIKI_COMPOSE_EXTRA_FILES:-}" ]; then
  IFS=':' read -ra _extra_files <<<"$SHIKI_COMPOSE_EXTRA_FILES"
  for _f in "${_extra_files[@]}"; do
    [ -n "$_f" ] || continue
    [ -f "$_f" ] || die "SHIKI_COMPOSE_EXTRA_FILES references missing file: $_f"
    compose_cmd+=(-f "$_f")
  done
fi

# Compose subcommands that don't need the runtime overlay can use this base.
compose_base_cmd=(
  docker compose
  --project-directory "$SHIKI_DIR"
  --project-name "$PROJECT_NAME"
  --env-file /dev/null
  -f "$RENDERED_COMPOSE"
)

# ---------- runtime overlay generation ----------
yaml_escape_dq() {
  local v="${1:-}"
  v="${v//\\/\\\\}"
  v="${v//\"/\\\"}"
  printf '%s' "$v"
}

write_runtime_overlay() {
  mkdir -p "$SESSION_RUNTIME_DIR"

  {
    printf 'services:\n'
    printf '  %s:\n' "$SERVICE_NAME"
    printf '    volumes:\n'
    local _i=0
    while [ "$_i" -lt "${#PROJECT_DIRS_ABS[@]}" ]; do
      printf '      - "%s:%s"\n' "${PROJECT_DIRS_ABS[$_i]}" "${PROJECT_CONTAINER_PATHS[$_i]}"
      _i=$((_i + 1))
    done
    if have_container_ssh_auth_sock; then
      printf '      - "%s:%s"\n' "$HOST_SSH_AUTH_SOCK" "$CONTAINER_SSH_AUTH_SOCK"
    fi
    if [ -f "$AIDER_CONFIG" ]; then
      printf '      - "%s:/root/.aider.conf.yml:ro"\n' "$AIDER_CONFIG"
    fi
    if [ ${#EXTRA_VOLUMES[@]} -gt 0 ]; then
      for _v in "${EXTRA_VOLUMES[@]}"; do
        printf '      - "%s"\n' "$(yaml_escape_dq "$_v")"
      done
    fi

    if have_container_ssh_auth_sock || [ ${#EXTRA_ENV[@]} -gt 0 ]; then
      printf '    environment:\n'
      if have_container_ssh_auth_sock; then
        printf '      SSH_AUTH_SOCK: "%s"\n' "$CONTAINER_SSH_AUTH_SOCK"
      fi
      if [ ${#EXTRA_ENV[@]} -gt 0 ]; then
        for _kv in "${EXTRA_ENV[@]}"; do
          local _key="${_kv%%=*}"
          local _val="${_kv#*=}"
          printf '      %s: "%s"\n' "$_key" "$(yaml_escape_dq "$_val")"
        done
      fi
    fi

    # Bridge-mode host aliases — emitted here (not in compose.yaml) because
    # mapping keys aren't interpolated by some compose versions.
    if [ "$NETWORK_MODE" = "bridge" ]; then
      printf '    extra_hosts:\n'
      printf '      %s: host-gateway\n' "$HOST_LOCALHOST_ALIAS"
      if [ "$HOST_GATEWAY_ALIAS" != "$HOST_LOCALHOST_ALIAS" ]; then
        printf '      %s: host-gateway\n' "$HOST_GATEWAY_ALIAS"
      fi
    fi
  } >"$RUNTIME_OVERLAY"
}

# ---------- image build / pull ----------
build_image() {
  local -a build_args=()
  [ "$BUILD_PULL" -eq 1 ] && build_args+=(--pull)
  [ "$BUILD_USE_CACHE" -eq 0 ] && build_args+=(--no-cache)

  echo-info "Building image '${IMAGE}' from ${SHIKI_DOCKERFILE} ..."
  if [ "$BUILD_PULL" -eq 1 ]; then
    echo-info "  Pulling latest upstream AiderDesk base image: ${UPSTREAM_IMAGE}"
  else
    echo-info "  Using local upstream AiderDesk base image: ${UPSTREAM_IMAGE}"
  fi
  if [ "$BUILD_USE_CACHE" -eq 1 ]; then
    echo-info "  Docker build cache: enabled"
  else
    echo-info "  Docker build cache: disabled"
  fi
  if [ -n "${AIDER_DESK_EXTENSIONS_OVERRIDE:-}" ]; then
    echo-info "  Overriding default extensions at build time: ${AIDER_DESK_EXTENSIONS_OVERRIDE}"
  elif [ -n "${AIDER_DESK_EXTENSIONS_APPEND:-}" ]; then
    echo-info "  Appending extensions at build time: ${AIDER_DESK_EXTENSIONS_APPEND}"
  else
    echo-info "  Using default built-in extensions"
  fi

  "${compose_base_cmd[@]}" build "${build_args[@]}" "$SERVICE_NAME"
  echo-ok "Image '${IMAGE}' built successfully."
}

pull_upstream_image() {
  echo-info "Pulling upstream AiderDesk base image: ${UPSTREAM_IMAGE}"
  docker pull "${UPSTREAM_IMAGE}"
  echo-ok "Upstream base image pulled successfully."
}

# ---------- extensions volume ----------
recreate_extensions_volume() {
  if docker ps -a --format '{{.Names}}' | grep -qx "$SESSION_NAME"; then
    echo-info "Removing existing container '$SESSION_NAME' so extensions can be refreshed."
    docker rm -f "$SESSION_NAME" >/dev/null
    if [ -d "${SESSION_DATA}" ]; then
      SESSION_ACTION=2
    else
      SESSION_ACTION=0
    fi
  fi

  echo-info "Refreshing extensions volume: ${EXTENSIONS_VOLUME}"
  docker volume rm -f "${EXTENSIONS_VOLUME}" >/dev/null 2>&1 || true
  docker volume create "${EXTENSIONS_VOLUME}" >/dev/null

  docker run --rm \
    --entrypoint sh \
    -v "${EXTENSIONS_VOLUME}:/extensions-volume" \
    "$IMAGE" \
    -lc 'mkdir -p /extensions-volume && if [ -d /usr/local/share/aider-desk/extensions-seed ]; then cp -a /usr/local/share/aider-desk/extensions-seed/. /extensions-volume/; fi && if ! find /extensions-volume -mindepth 1 -maxdepth 1 -print -quit | grep -q .; then echo "FATAL: extensions volume was not populated from image seed" >&2; exit 1; fi'
}

# ---------- maintenance branches (exit without starting a container) ----------
if [ "$PULL_IMAGE" -eq 1 ] && { [ "$REBUILD_IMAGE" -eq 0 ] || [ "$BUILD_PULL" -eq 0 ]; }; then
  pull_upstream_image
fi

if [ "$REBUILD_IMAGE" -eq 1 ]; then
  build_image
else
  docker image inspect "$IMAGE" >/dev/null 2>&1 || {
    echo-info "Image '${IMAGE}' not found locally — building from Dockerfile ..."
    build_image
  }
fi

if [ "$UPDATE_EXTENSIONS" -eq 1 ]; then
  recreate_extensions_volume
fi

if [ "$REBUILD_IMAGE" -eq 1 ] || [ "$UPDATE_EXTENSIONS" -eq 1 ] || [ "$PULL_IMAGE" -eq 1 ]; then
  if [ "$PULL_IMAGE" -eq 1 ] && [ "$REBUILD_IMAGE" -eq 1 ] && [ "$UPDATE_EXTENSIONS" -eq 1 ]; then
    echo-ok "Maintenance complete: upstream image pulled, local image rebuilt, and extensions refreshed."
  elif [ "$PULL_IMAGE" -eq 1 ] && [ "$REBUILD_IMAGE" -eq 1 ]; then
    echo-ok "Maintenance complete: upstream image pulled and local image rebuilt."
  elif [ "$REBUILD_IMAGE" -eq 1 ] && [ "$UPDATE_EXTENSIONS" -eq 1 ]; then
    echo-ok "Maintenance complete: image rebuilt and extensions refreshed."
  elif [ "$REBUILD_IMAGE" -eq 1 ]; then
    echo-ok "Maintenance complete: image rebuilt."
  elif [ "$UPDATE_EXTENSIONS" -eq 1 ]; then
    echo-ok "Maintenance complete: extensions refreshed."
  else
    echo-ok "Maintenance complete: upstream image pulled."
  fi
  exit 0
fi

# ---------- ensure extensions volume + session dirs + runtime overlay ----------
docker volume inspect "${EXTENSIONS_VOLUME}" >/dev/null 2>&1 || recreate_extensions_volume

mkdir -p "$SESSION_DATA" "$SESSION_CLAUDE" "$SESSION_MISE_CONFIG" "$SESSION_MISE_DATA" "$SESSION_MISE_CACHE"

# Refuse to start if the host's Claude Code settings file is missing — the
# compose template bind-mounts it read-only into the container, and Docker
# would otherwise auto-create an empty directory at that path.
if [ ! -f "$CLAUDE_HOST/settings.json" ]; then
  echo-err "Missing ${CLAUDE_HOST}/settings.json (bind-mounted into the container)."
  echo-err "Run \`chezmoi apply ~/.claude/settings.json\` to materialize it, then re-run shiki."
  exit 1
fi

write_runtime_overlay

print_mount_banner() {
  local _i=0
  while [ "$_i" -lt "${#PROJECT_DIRS_ABS[@]}" ]; do
    echo-info "  Project:  ${PROJECT_DIRS_ABS[$_i]} → ${PROJECT_CONTAINER_PATHS[$_i]}"
    _i=$((_i + 1))
  done
  echo-info "  Config:   ${AIDER_DESK_GLOBAL}/{agents,commands,hooks,prompts,rules,skills} → /root/.aider-desk/<subdir>"
  echo-info "  Exts:     volume ${EXTENSIONS_VOLUME} → /root/.aider-desk/extensions"
  echo-info "  Codex:    ${CODEX_AUTH_HOST_PATH} → ${CODEX_AUTH_CONTAINER_PATH}"
  if [ -f "$AIDER_CONFIG" ]; then
    echo-info "  Aider:    ${AIDER_CONFIG} → /root/.aider.conf.yml (ro)"
  fi
  echo-info "  Data:     ${SESSION_DATA} → /app/state${1:+ ($1)}"
  echo-info "  Claude:   ${SESSION_CLAUDE} → /root/.claude"
  echo-info "            ${CLAUDE_HOST}/settings.json → /root/.claude/settings.json (ro)"
  echo-info "  Mise:     ${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/mise/{config,data,cache}"
  if [ "$HOST_PORT" = "0" ]; then
    echo-info "  UI:       http://localhost:<auto-assigned> (reported on startup)"
  else
    echo-info "  UI:       http://localhost:${HOST_PORT}"
  fi
  echo-info "  Orb:      http://${SESSION_NAME}.${PROJECT_NAME}.orb.local"
  if [ "$NETWORK_MODE" = "host" ]; then
    echo-info "  Network:  host (localhost inside container = host localhost)"
    echo-info "  Host:     localhost:<port> → host machine localhost"
  else
    echo-info "  Network:  bridge"
    echo-info "  Host:     ${HOST_LOCALHOST_ALIAS}:<port> → host machine localhost"
  fi
}

print_run_hints() {
  local port="${1:-}"
  [ -n "$port" ] || port="$HOST_PORT"
  if [ -z "$port" ] || [ "$port" = "0" ]; then
    echo-info "  UI:   http://localhost:<unknown> (port lookup failed)"
  else
    echo-info "  UI:   http://localhost:${port}"
  fi
  echo-info "  Orb:  http://${SESSION_NAME}.${PROJECT_NAME}.orb.local"
  echo-info "  Logs: docker logs -f $SESSION_NAME"
  echo-info "  Stop: docker stop $SESSION_NAME"
}

container_network_mode() {
  docker inspect --format '{{.HostConfig.NetworkMode}}' "$1" 2>/dev/null || true
}

container_aider_desk_port() {
  local env_line port
  env_line="$(docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$1" 2>/dev/null | grep '^AIDER_DESK_PORT=' | tail -n 1 || true)"
  port="${env_line#AIDER_DESK_PORT=}"
  [ -n "$port" ] || port="$DEFAULT_PORT"
  printf '%s\n' "$port"
}

# Resolve the actual host port currently bound by `container`. Works for
# both bridge mode (reads PortBindings — handles random Docker-assigned
# ports) and host mode (reads the in-container listen port from the
# container's env). Prints empty on failure.
inspect_host_port() {
  local container="$1" network port
  network="$(container_network_mode "$container")"
  if [ "$network" = "host" ]; then
    container_aider_desk_port "$container"
  else
    port="$(docker inspect --format '{{range $p, $b := .HostConfig.PortBindings}}{{range $b}}{{.HostPort}}{{end}}{{end}}' "$container" 2>/dev/null || true)"
    printf '%s\n' "$port"
  fi
}

echo-debug "compose runtime overlay: $RUNTIME_OVERLAY"
echo-debug "AIDER_DESK_PROJECTS=${PROJECT_CONTAINER_PATH_LIST}"
echo-debug "host SSH_AUTH_SOCK source: ${HOST_SSH_AUTH_SOCK:-<unset>}"
echo-debug "container SSH_AUTH_SOCK target: ${CONTAINER_SSH_AUTH_SOCK:-<unset>}"
echo-debug "using host-services SSH socket: ${USE_HOST_SERVICES_SSH_AUTH_SOCK}"
echo-debug "network mode: ${NETWORK_MODE}"

# ---------- dispatch ----------
case "$SESSION_ACTION" in
0)
  echo-info "Creating new session: $SESSION_NAME"
  print_mount_banner
  "${compose_cmd[@]}" up -d "$SERVICE_NAME"
  echo-ok "Session '$SESSION_NAME' started."
  print_run_hints "$(inspect_host_port "$SESSION_NAME")"
  ;;

1)
  container_status="$(docker inspect --format '{{.State.Status}}' "$SESSION_NAME" 2>/dev/null || echo "unknown")"
  bound_port="$(inspect_host_port "$SESSION_NAME")"
  [ -n "$bound_port" ] || bound_port="$HOST_PORT"

  if [ "$container_status" = "running" ]; then
    echo-info "Session '$SESSION_NAME' is already running."
    print_run_hints "$bound_port"
  else
    echo-info "Resuming session: $SESSION_NAME"
    # Only warn about port mismatch if the user explicitly asked for a
    # different port — the default HOST_PORT=0 means "any port," so
    # whatever's bound is fine.
    if [ "$HOST_PORT_EXPLICIT" -eq 1 ] && [ "$bound_port" != "$HOST_PORT" ]; then
      echo-warn "  Container was created with port ${bound_port}, ignoring -p ${HOST_PORT}."
    fi
    "${compose_base_cmd[@]}" start "$SERVICE_NAME"
    echo-ok "Session '$SESSION_NAME' resumed."
    print_run_hints "$bound_port"
  fi
  ;;

2)
  echo-info "Restoring session: $SESSION_NAME (container was removed, data preserved)"
  print_mount_banner "existing"
  "${compose_cmd[@]}" up -d "$SERVICE_NAME"
  echo-ok "Session '$SESSION_NAME' restored."
  print_run_hints "$(inspect_host_port "$SESSION_NAME")"
  ;;
esac
