#!/usr/bin/env bash
# brownie: launch AiderDesk in a container with per-session persistent data
#
# Why "Brownie"?
#   In Scottish/English folklore, a Brownie is a helpful house-spirit that
#   tidies and assists quietly at night—so long as it's respected. This script
#   wraps AiderDesk in a container with persistent sessions, SSH agent
#   forwarding for 1Password commit signing, and sensible mounts.
#
# Usage:
#   brownie [wrapper-opts] -- [docker run opts ...]
#
# Behavior:
#   • Args BEFORE `--` are wrapper options.
#   • Args AFTER  `--` are passed directly to `docker run`.
#   • Git identity and signing config are injected via env vars.
#   • AiderDesk runs as a headless web server (detached).
#   • Use --rebuild to (re)build the local image from the Dockerfile,
#     pulling the latest upstream AiderDesk base image in the process.
#
# Session lifecycle:
#   • Session data lives at ~/.local/share/aider-desk/<session>/data
#   • If a container exists (running or stopped), it is reused.
#   • If the container is gone but the data directory remains,
#     a new container is created pointing at the existing data.
#   • Multiple -d/--dir flags mount several directories into the container
#     and all are registered as AiderDesk projects.
#   • Specifying `-n <name>` without a random suffix allows
#     deterministic session restore after container removal.

set -Eeuo pipefail

# ---------- defaults ----------
DEFAULT_IMAGE="brownie:latest"
DEFAULT_PREFIX="brownie"
DEFAULT_PORT=24337

IMAGE="$DEFAULT_IMAGE"
PULL_IMAGE=0
REBUILD_IMAGE=0
SESSION_NAME=""
HOST_PORT="$DEFAULT_PORT"
PROJECT_DIRS=()
DOCKER_EXTRAS=()

BROWNIE_ABOUT=$'Brownie — a friendly nod to the Scottish/English household spirit.\n\
In folklore, a Brownie is a quiet helper who keeps things tidy if treated well.\n\
This tool wraps AiderDesk in a container with persistent sessions, SSH agent\n\
forwarding for 1Password commit signing, and sensible mounts for your project.\n\
Be respectful; keep your config in order—and the work flows. 🙂'

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

usage() {
  cat <<'USAGE'
Usage:
  brownie [wrapper-opts] -- [docker run opts ...]

Wrapper options (before --):
  -n, --name         Session/container name (default: brownie-<project>).
                     Deterministic names allow restoring sessions even
                     after the container has been removed.
  -i, --image        Image to run (default: brownie:latest).
  -p, --port         Host port for AiderDesk UI (default: 24337).
  -d, --dir          Project directory to mount (default: $PWD).
                     Accepts one or more directory arguments after the flag,
                     and may also be specified multiple times. All mounted
                     directories are registered as AiderDesk projects.
                     The first directory is used for session naming.
      --pull         Pull the upstream base image and rebuild before running.
      --rebuild      (Re)build the local brownie image from the Dockerfile.
                     Implies pulling the latest upstream AiderDesk image.
      --about        Explain why this tool is named "Brownie".
  -h, --help         Show this help and exit.

Required environment variables:
  GIT_USER_NAME      Git identity: user name.
  GIT_USER_EMAIL     Git identity: user email.

Optional environment variables:
  GIT_SIGNING_KEY    SSH public key for commit signing.
  GIT_SIGN_COMMITS   "true" (default when GIT_SIGNING_KEY is set) or "false".

SSH agent forwarding (required for commit signing):
  The 1Password SSH agent socket at ~/.1password/agent.sock is
  automatically mounted when it exists.

Mounts (automatic):
  Project dir(s)           → /projects/<subdir>  (one mount per supplied dir)
  ~/.local/share/aider-desk/<session>/data
                           → /app/state            (persistent data, survives container removal)
  ~/.config/aider-desk/    → /root/.aider-desk/    (global hooks, skills, etc.)
  ~/.config/aider/aider.conf.yml
                           → /root/.aider.conf.yml (aider config, read-only)
  ~/.1password/agent.sock  → /run/1password/agent.sock  (SSH agent, if exists)

Session restore:
  Data is stored on the host at ~/.local/share/aider-desk/<session>/data.
  If the container is removed, running brownie with the same -n <name>
  will create a new container that picks up the existing data.

Examples:
  brownie                                         # auto-named from project dir
  brownie -n my-project                           # deterministic name, restorable
  brownie -n my-project                           # same command restores the session
  brownie -p 8080
  brownie -d ~/code/my-app -n my-app
  brownie -d ~/code/app ~/code/lib -n my-app     # one -d, multiple dirs
  brownie -d ~/code/app -d ~/code/lib -n my-app  # repeated -d also works
  brownie --pull -n docs -- --network host
USAGE
}

have() { command -v "$1" >/dev/null 2>&1; }
lower() { tr '[:upper:]' '[:lower:]'; }

sanitize_docker_name() {
  local in="${1:-}" out
  out="$(printf '%s' "$in" | lower | tr -c 'a-z0-9._-' '-')"
  out="$(printf '%s' "$out" | sed -E 's/^[^a-z0-9]+//')"
  out="$(printf '%s' "$out" | sed -E 's/[-._]+$//')"
  [ -n "$out" ] || out="session"
  out="${out:0:128}"
  printf '%s\n' "$out"
}

list_existing_sessions() {
  docker ps -a --filter "name=${DEFAULT_PREFIX}-" \
    --format "table {{.Names}}\t{{.Status}}\t{{.CreatedAt}}" 2>/dev/null || true
}

get_existing_session_names() {
  docker ps -a --filter "name=${DEFAULT_PREFIX}-" \
    --format "{{.Names}}" 2>/dev/null | sort || true
}

# List sessions that have data on disk (including those without containers)
get_data_sessions() {
  local data_root="${HOME}/.local/share/aider-desk"
  if [ -d "$data_root" ]; then
    find "$data_root" -maxdepth 1 -mindepth 1 -type d -exec basename {} \; 2>/dev/null | sort || true
  fi
}

prompt_session_choice() {
  local -a container_sessions=() data_only_sessions=() all_sessions=()

  # Sessions with live containers
  while IFS= read -r s; do
    [ -n "$s" ] && container_sessions+=("$s")
  done < <(get_existing_session_names)

  # Sessions with data on disk but no container
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    local found=0
    for cs in "${container_sessions[@]+"${container_sessions[@]}"}"; do
      [ "$cs" = "$s" ] && {
        found=1
        break
      }
    done
    [ "$found" -eq 0 ] && data_only_sessions+=("$s")
  done < <(get_data_sessions)

  all_sessions=("${container_sessions[@]+"${container_sessions[@]}"}" "${data_only_sessions[@]+"${data_only_sessions[@]}"}")

  if [ ${#all_sessions[@]} -eq 0 ]; then
    SESSION_NAME="$(make_default_session_name)"
    return 0 # new session
  fi

  echo "Found existing sessions:"
  echo ""
  local i=1
  for s in "${container_sessions[@]+"${container_sessions[@]}"}"; do
    local status
    status="$(docker inspect --format '{{.State.Status}}' "$s" 2>/dev/null || echo "unknown")"
    echo "  $i) $s  [container: ${status}]"
    ((i++))
  done
  for s in "${data_only_sessions[@]+"${data_only_sessions[@]}"}"; do
    echo "  $i) $s  [data only — container removed]"
    ((i++))
  done
  echo ""
  echo "Options:"
  echo "  Enter a number to resume a session"
  echo "  Or press Enter to create a new session"
  echo ""

  local choice
  read -r -p "Choice: " choice

  if [ -z "$choice" ]; then
    SESSION_NAME="$(make_default_session_name)"
    return 0 # new session
  fi

  if [[ "$choice" =~ ^[0-9]+$ ]] &&
    [ "$choice" -ge 1 ] &&
    [ "$choice" -le ${#all_sessions[@]} ]; then
    SESSION_NAME="${all_sessions[$((choice - 1))]}"

    # Check if this is a container session or data-only
    if docker ps -a --format '{{.Names}}' | grep -qx "$SESSION_NAME"; then
      return 1 # resume existing container
    else
      return 2 # restore from data (no container)
    fi
  fi

  die "Invalid choice."
}

make_default_session_name() {
  local base
  base="$(basename "$PROJECT_DIR" | sanitize_docker_name)"
  [ -n "$base" ] || base="workspace"
  sanitize_docker_name "${DEFAULT_PREFIX}-${base}"
}

print_about() { printf '%s\n' "$BROWNIE_ABOUT"; }

# ---------- parse args ----------
parse_args() {
  local after_delim=0
  while [ $# -gt 0 ]; do
    case "$1" in
    --)
      after_delim=1
      shift
      break
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --about)
      print_about
      exit 0
      ;;
    -n | --name)
      [ $# -ge 2 ] || die "--name requires an argument"
      SESSION_NAME="$(sanitize_docker_name "${DEFAULT_PREFIX}-$2")"
      shift 2
      ;;
    -i | --image)
      [ $# -ge 2 ] || die "--image requires an argument"
      IMAGE="$2"
      shift 2
      ;;
    -p | --port)
      [ $# -ge 2 ] || die "--port requires an argument"
      HOST_PORT="$2"
      shift 2
      ;;
    -d | --dir)
      shift
      local added=0
      while [ $# -gt 0 ]; do
        case "$1" in
        --)
          break
          ;;
        -*)
          break
          ;;
        *)
          PROJECT_DIRS+=("$1")
          added=1
          shift
          ;;
        esac
      done
      [ "$added" -eq 1 ] || die "--dir requires at least one directory argument"
      ;;
    --pull)
      PULL_IMAGE=1
      shift
      ;;
    --rebuild)
      REBUILD_IMAGE=1
      shift
      ;;
    *) die "Unknown option: $1 (use -- to pass extra flags to docker run)" ;;
    esac
  done

  if [ "$after_delim" -eq 1 ]; then
    while [ $# -gt 0 ]; do
      DOCKER_EXTRAS+=("$1")
      shift
    done
  fi
}

parse_args "$@"

# ---------- defaults for dirs ----------
if [ ${#PROJECT_DIRS[@]} -eq 0 ]; then
  PROJECT_DIRS=("$PWD")
fi

# ---------- preflight ----------
have docker || die "docker not found in PATH."
have git || die "git not found in PATH (needed to read host identity)."

: "${GIT_USER_NAME:=$(git config user.name 2>/dev/null || true)}"
: "${GIT_USER_EMAIL:=$(git config user.email 2>/dev/null || true)}"

[ -n "${GIT_USER_NAME:-}" ] || die "GIT_USER_NAME is not set and git config user.name is empty."
[ -n "${GIT_USER_EMAIL:-}" ] || die "GIT_USER_EMAIL is not set and git config user.email is empty."

# Resolve and validate all project dirs; primary dir is first entry
PROJECT_DIRS_ABS=()
for _d in "${PROJECT_DIRS[@]}"; do
  _abs="$(cd "$_d" 2>/dev/null && pwd)" || die "Project directory does not exist: $_d"
  [ -d "$_abs" ] || die "Project directory does not exist: $_d"
  PROJECT_DIRS_ABS+=("$_abs")
done
PROJECT_DIR="${PROJECT_DIRS_ABS[0]}"

# ---------- paths ----------
AIDER_DESK_GLOBAL="${HOME}/.config/aider-desk"
AIDER_DESK_DATA_ROOT="${HOME}/.local/share/aider-desk"
AIDER_CONFIG="${HOME}/.config/aider/aider.conf.yml"
SSH_AGENT_SOCK="${HOME}/.1password/agent.sock"

# Build per-directory container paths — each dir is mounted AS a named
# subdirectory inside /projects (e.g. host /home/user/a-1 → /projects/a-1).
# If basenames collide, append a numeric suffix to keep targets unique.
PROJECT_CONTAINER_PATHS=()
for _d in "${PROJECT_DIRS_ABS[@]}"; do
  _base="$(basename -- "$_d")"
  _name="$_base"
  _suffix=2
  while :; do
    _exists=0
    for _cp in "${PROJECT_CONTAINER_PATHS[@]}"; do
      if [ "$_cp" = "/projects/$_name" ]; then
        _exists=1
        break
      fi
    done
    [ "$_exists" -eq 0 ] && break
    _name="${_base}-${_suffix}"
    _suffix=$((_suffix + 1))
  done
  PROJECT_CONTAINER_PATHS+=("/projects/${_name}")
done
# Colon-separated list for AIDER_DESK_PROJECTS env var
PROJECT_CONTAINER_PATH_LIST=""
for _cp in "${PROJECT_CONTAINER_PATHS[@]}"; do
  if [ -z "$PROJECT_CONTAINER_PATH_LIST" ]; then
    PROJECT_CONTAINER_PATH_LIST="$_cp"
  else
    PROJECT_CONTAINER_PATH_LIST="${PROJECT_CONTAINER_PATH_LIST}:${_cp}"
  fi
done
# Primary (for display/legacy)
PROJECT_BASENAME="$(basename "$PROJECT_DIR")"
PROJECT_CONTAINER_PATH="${PROJECT_CONTAINER_PATHS[0]}"

mkdir -p \
  "${AIDER_DESK_GLOBAL}/hooks" \
  "${AIDER_DESK_GLOBAL}/skills" \
  "${AIDER_DESK_GLOBAL}/agents" \
  "${AIDER_DESK_GLOBAL}/commands" \
  "${AIDER_DESK_GLOBAL}/prompts" \
  "${AIDER_DESK_GLOBAL}/rules"

# ---------- session resolution ----------
# Returns:
#   0 = new session
#   1 = resume existing container (stopped or running)
#   2 = restore from data directory (container removed)
SESSION_ACTION=0

if [ -z "$SESSION_NAME" ]; then
  # Default session name is based on the current working directory basename
  default_name="$(make_default_session_name)"
  SESSION_NAME="$default_name"
  if docker ps -a --format '{{.Names}}' | grep -qx "$default_name"; then
    SESSION_ACTION=1 # container exists
  elif [ -d "${AIDER_DESK_DATA_ROOT}/${default_name}/data" ]; then
    SESSION_ACTION=2 # data exists, no container
  else
    SESSION_ACTION=0 # fresh new session
  fi
else
  # Name was provided explicitly
  if docker ps -a --format '{{.Names}}' | grep -qx "$SESSION_NAME"; then
    SESSION_ACTION=1 # container exists
  elif [ -d "${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/data" ]; then
    SESSION_ACTION=2 # data exists, no container
  else
    SESSION_ACTION=0 # fresh
  fi
fi

# Session data directory on host
SESSION_DATA="${AIDER_DESK_DATA_ROOT}/${SESSION_NAME}/data"

# ---------- locate Dockerfile (for --rebuild / --pull on local image) ----------
BROWNIE_SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
# Walk up from script dir to find the repo root (contains devcontainer/)
BROWNIE_DOCKERFILE="${BROWNIE_DOCKERFILE:-}"
if [ -z "$BROWNIE_DOCKERFILE" ]; then
  # Try common relative paths from the script location
  for candidate in \
    "${BROWNIE_SCRIPT_DIR}/../../devcontainer/brownie.Dockerfile" \
    "${BROWNIE_SCRIPT_DIR}/../../../devcontainer/brownie.Dockerfile" \
    "${HOME}/.local/share/chezmoi/devcontainer/brownie.Dockerfile"; do
    candidate="$(realpath -m "$candidate")"
    if [ -f "$candidate" ]; then
      BROWNIE_DOCKERFILE="$candidate"
      break
    fi
  done
fi

build_image() {
  if [ -z "$BROWNIE_DOCKERFILE" ] || [ ! -f "$BROWNIE_DOCKERFILE" ]; then
    die "Cannot find brownie.Dockerfile. Set BROWNIE_DOCKERFILE=/path/to/brownie.Dockerfile or ensure the chezmoi source tree is present."
  fi
  local build_context
  build_context="$(dirname "$BROWNIE_DOCKERFILE")"
  echo "Building image '${IMAGE}' from ${BROWNIE_DOCKERFILE} ..."
  echo "  (pulling latest upstream AiderDesk base image)"
  docker build \
    --pull \
    --file "$BROWNIE_DOCKERFILE" \
    --tag "$IMAGE" \
    "$build_context"
  echo "Image '${IMAGE}' built successfully."
  echo ""
}

# ---------- image pull / build ----------
if [ "$REBUILD_IMAGE" -eq 1 ] || [ "$PULL_IMAGE" -eq 1 ]; then
  build_image
else
  docker image inspect "$IMAGE" >/dev/null 2>&1 || {
    echo "Image '${IMAGE}' not found locally — building from Dockerfile ..."
    build_image
  }
fi

# ---------- helper: build docker run command ----------
run_new_container() {
  # Ensure data directory exists
  mkdir -p "$SESSION_DATA"

  # --- Environment ---
  local -a docker_env=(
    -e "GIT_USER_NAME=${GIT_USER_NAME}"
    -e "GIT_USER_EMAIL=${GIT_USER_EMAIL}"
    -e "AIDER_DESK_PROJECTS=${PROJECT_CONTAINER_PATH_LIST}"
    -e "AIDER_DESK_DATA_DIR=/app/state"
  )

  # Signing key (fall back to host git config)
  if [ -z "${GIT_SIGNING_KEY:-}" ]; then
    local host_gpg_format
    host_gpg_format="$(git config gpg.format 2>/dev/null || true)"
    if [ "$host_gpg_format" = "ssh" ]; then
      : "${GIT_SIGNING_KEY:=$(git config user.signingkey 2>/dev/null || true)}"
    fi
  fi
  if [ -n "${GIT_SIGNING_KEY:-}" ]; then
    docker_env+=(-e "GIT_SIGNING_KEY=${GIT_SIGNING_KEY}")
  fi
  if [ -n "${GIT_SIGN_COMMITS:-}" ]; then
    docker_env+=(-e "GIT_SIGN_COMMITS=${GIT_SIGN_COMMITS}")
  fi

  # SSH agent
  if [ -S "$SSH_AGENT_SOCK" ]; then
    docker_env+=(-e "SSH_AUTH_SOCK=/run/1password/agent.sock")
  elif [ -n "${GIT_SIGNING_KEY:-}" ]; then
    echo "WARNING: GIT_SIGNING_KEY is set but ${SSH_AGENT_SOCK} not found." >&2
    echo "         Commit signing will fail without the SSH agent socket." >&2
  fi

  # --- Volumes ---
  # Each project dir is mounted as /projects/<basename>, so the named directory
  # appears inside /projects rather than its contents being merged into /projects.
  local -a docker_volumes=()
  local _vi=0
  while [ "$_vi" -lt "${#PROJECT_DIRS_ABS[@]}" ]; do
    docker_volumes+=(-v "${PROJECT_DIRS_ABS[$_vi]}:${PROJECT_CONTAINER_PATHS[$_vi]}")
    _vi=$((_vi + 1))
  done
  docker_volumes+=(
    -v "${SESSION_DATA}:/app/state"
    -v "${AIDER_DESK_GLOBAL}:/root/.aider-desk"
  )

  if [ -f "$AIDER_CONFIG" ]; then
    docker_volumes+=(-v "${AIDER_CONFIG}:/root/.aider.conf.yml:ro")
  fi

  if [ -S "$SSH_AGENT_SOCK" ]; then
    docker_volumes+=(-v "${SSH_AGENT_SOCK}:/run/1password/agent.sock")
  fi

  # --- Port ---
  local -a docker_ports=(-p "${HOST_PORT}:24337")

  echo "DEBUG: docker run volumes:" >&2
  for _v in "${docker_volumes[@]}"; do echo "  $_v" >&2; done
  echo "DEBUG: AIDER_DESK_PROJECTS=${PROJECT_CONTAINER_PATH_LIST}" >&2

  docker run \
    -d \
    --name "$SESSION_NAME" \
    "${docker_volumes[@]}" \
    "${docker_env[@]}" \
    "${docker_ports[@]}" \
    ${DOCKER_EXTRAS[@]+"${DOCKER_EXTRAS[@]}"} \
    "$IMAGE"
}

# ---------- run ----------
case "$SESSION_ACTION" in
0)
  # New session
  echo "Creating new session: $SESSION_NAME"
  _pi=0
  while [ "$_pi" -lt "${#PROJECT_DIRS_ABS[@]}" ]; do
    echo "  Project:  ${PROJECT_DIRS_ABS[$_pi]} → ${PROJECT_CONTAINER_PATHS[$_pi]}"
    _pi=$((_pi + 1))
  done
  echo "  Config:   ${AIDER_DESK_GLOBAL} → /root/.aider-desk"
  if [ -f "$AIDER_CONFIG" ]; then
    echo "  Aider:    ${AIDER_CONFIG} → /root/.aider.conf.yml (ro)"
  fi
  echo "  Data:     ${SESSION_DATA} → /app/state"
  echo "  UI:       http://localhost:${HOST_PORT}"
  echo ""

  run_new_container

  echo ""
  echo "Session '$SESSION_NAME' started."
  echo "  UI:   http://localhost:${HOST_PORT}"
  echo "  Logs: docker logs -f $SESSION_NAME"
  echo "  Stop: docker stop $SESSION_NAME"
  ;;

1)
  # Existing container (running or stopped)
  container_status="$(docker inspect --format '{{.State.Status}}' "$SESSION_NAME" 2>/dev/null || echo "unknown")"
  # Retrieve the host port the container was originally created with
  bound_port="$(docker inspect --format '{{range $p, $b := .HostConfig.PortBindings}}{{range $b}}{{.HostPort}}{{end}}{{end}}' "$SESSION_NAME" 2>/dev/null || echo "$HOST_PORT")"
  [ -n "$bound_port" ] || bound_port="$HOST_PORT"

  if [ "$container_status" = "running" ]; then
    echo "Session '$SESSION_NAME' is already running."
    echo "  UI:   http://localhost:${bound_port}"
    echo "  Logs: docker logs -f $SESSION_NAME"
    echo "  Stop: docker stop $SESSION_NAME"
  else
    echo "Resuming session: $SESSION_NAME"
    if [ "$bound_port" != "$HOST_PORT" ]; then
      echo "  NOTE: Container was created with port ${bound_port}, ignoring -p ${HOST_PORT}."
    fi
    docker start "$SESSION_NAME"
    echo ""
    echo "Session '$SESSION_NAME' resumed."
    echo "  UI:   http://localhost:${bound_port}"
    echo "  Logs: docker logs -f $SESSION_NAME"
    echo "  Stop: docker stop $SESSION_NAME"
  fi
  ;;

2)
  # Data exists but container was removed — restore
  echo "Restoring session: $SESSION_NAME (container was removed, data preserved)"
  _pi=0
  while [ "$_pi" -lt "${#PROJECT_DIRS_ABS[@]}" ]; do
    echo "  Project:  ${PROJECT_DIRS_ABS[$_pi]} → ${PROJECT_CONTAINER_PATHS[$_pi]}"
    _pi=$((_pi + 1))
  done
  echo "  Config:   ${AIDER_DESK_GLOBAL} → /root/.aider-desk"
  if [ -f "$AIDER_CONFIG" ]; then
    echo "  Aider:    ${AIDER_CONFIG} → /root/.aider.conf.yml (ro)"
  fi
  echo "  Data:     ${SESSION_DATA} → /app/state (existing)"
  echo "  UI:       http://localhost:${HOST_PORT}"
  echo ""

  run_new_container

  echo ""
  echo "Session '$SESSION_NAME' restored."
  echo "  UI:   http://localhost:${HOST_PORT}"
  echo "  Logs: docker logs -f $SESSION_NAME"
  echo "  Stop: docker stop $SESSION_NAME"
  ;;
esac
