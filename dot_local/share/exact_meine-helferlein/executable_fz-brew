#!/usr/bin/env bash
#
# fz-brew - fzf-powered Homebrew helpers
#
# Consolidates: fzf-brew-install, fzf-brew-uninstall, fzf-brew-update

set -o pipefail
if [[ -n "$DEBUG" ]]; then
  set -x
fi

fail() {
  printf '%s\n' "$1" >&2
  exit "${2-1}"
}

has() {
  which "$@" > /dev/null 2>&1
}

if ! has brew; then
  fail "Can't find brew in your PATH"
fi

usage() {
  cat <<USAGE
Usage: fz-brew <command>

Commands:
  install     Select one or more formulae to install
  uninstall   Select one or more installed formulae to uninstall
  update      Select one or more installed formulae to upgrade
USAGE
}

cmd_install() {
  local inst
  # shellcheck disable=SC2068
  inst=$(brew search $@ | fzf -m --preview 'brew info {}')
  if [[ $inst ]]; then
    for prog in $inst; do
      brew install "$prog"
    done
  fi
}

cmd_uninstall() {
  local uninst
  uninst=$(brew leaves | fzf -m --preview 'brew info {}')
  if [[ $uninst ]]; then
    for prog in $uninst; do
      brew uninstall "$prog"
    done
  fi
}

cmd_update() {
  local upd
  upd=$(brew leaves | fzf -m --preview 'brew info {}')
  if [[ $upd ]]; then
    for prog in $upd; do
      brew upgrade "$prog"
    done
  fi
}

case "${1:-}" in
  install)   shift; cmd_install "$@" ;;
  uninstall) shift; cmd_uninstall "$@" ;;
  update)    shift; cmd_update "$@" ;;
  -h|--help) usage ;;
  *)         usage; exit 1 ;;
esac
