#!/bin/bash
# vim: ft=bash
# Generate mise.toml profile files from chezmoi data.
# Each profile drops a mise.toml into an arbitrary directory with env vars
# sourced from 1Password (op:// URIs) or static values.
# Hash: {{ if .mise.profiles }}{{ .mise.profiles | toJson | sha256sum }}{{ else }}empty{{ end }}

set -euo pipefail

{{ if .mise.profiles -}}
{{ range .mise.profiles }}
PROFILE_DIR="{{ .dir }}"
mkdir -p "${PROFILE_DIR}"

cat > "${PROFILE_DIR}/mise.toml" << 'MISE_EOF'
# Generated by chezmoi - do not edit directly
[env]
{{ range .env -}}
{{ if .value -}}
{{ .name }} = {{ .value | quote }}
{{ else -}}
{{ .name }} = "{{ "{{" }} op://{{ $.op_vault }}/{{ .op_item }}/{{ .op_field }} {{ "}}" }}"
{{ end -}}
{{ end -}}
MISE_EOF

echo "Generated mise profile: ${PROFILE_DIR}/mise.toml"

if command -v mise &>/dev/null; then
  mise trust "${PROFILE_DIR}/mise.toml"
  echo "Trusted mise profile: ${PROFILE_DIR}/mise.toml"
fi
{{ end }}
{{- else }}
echo "No mise profiles configured"
{{- end }}
