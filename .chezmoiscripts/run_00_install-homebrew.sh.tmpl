#!/bin/bash
{{- if eq .chezmoi.os "darwin" }}

set -e # -e: exit on error

LOCAL_BIN="${HOME}/.local/bin"
if [ -d "${LOCAL_BIN}" ]; then
  export PATH="${LOCAL_BIN}:${PATH}"
fi

_log_info()  { if command -v echo-info  &>/dev/null; then echo-info  "$@"; else echo "[INFO] --- $*"; fi; }
_log_ok()    { if command -v echo-ok    &>/dev/null; then echo-ok    "$@"; else echo "[SUCCESS] --- $*"; fi; }
_log_warn()  { if command -v echo-warn  &>/dev/null; then echo-warn  "$@"; else echo "[WARN] --- $*" >&2; fi; }
_log_err()   { if command -v echo-err   &>/dev/null; then echo-err   "$@"; else echo "[ERROR] --- $*" >&2; fi; }

if ! command -v brew &>/dev/null; then
  _log_info "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # Add Homebrew to PATH for the remainder of this run
  if [ -f /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -f /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi

  _log_ok "Homebrew installed successfully."
else
  _log_ok "Homebrew is already installed."
fi
{{- end }}
