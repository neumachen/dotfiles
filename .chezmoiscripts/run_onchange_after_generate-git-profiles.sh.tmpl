#!/bin/bash
# vim: ft=bash
# Generate git profile files from chezmoi data
# Hash: {{ if .git.profiles }}{{ .git.profiles | toJson | sha256sum }}{{ else }}empty{{ end }}

set -euo pipefail

PROFILES_DIR="${HOME}/.config/git/profiles"
mkdir -p "${PROFILES_DIR}"

{{ if .git.profiles -}}
{{ range .git.profiles }}
cat > "${PROFILES_DIR}/{{ .name }}" << 'PROFILE_EOF'
# vim:ft=gitconfig
# Generated by chezmoi - do not edit directly
[user]
  email = {{ .email }}
{{- if .signingKey }}
  signingKey = {{ .signingKey }}
{{- end }}
{{- if .userName }}
  name = {{ .userName }}
{{- end }}
PROFILE_EOF

echo "Generated git profile: {{ .name }}"
{{ end }}
{{- else }}
echo "No git profiles configured"
{{- end }}
