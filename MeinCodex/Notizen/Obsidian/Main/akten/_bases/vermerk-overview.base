filters:
  and:
    - file.hasTag("vermerk")
    - 'note["type"] == "vermerk"'

formulas:
  titleLink: 'file.asLink(title)'
  akteLink: 'note["reference.akten.link"]'
  recordedOn: 'note["modified_at.utc"]'

properties:
  formula.titleLink:
    displayName: Title
  formula.akteLink:
    displayName: Akte
  formula.recordedOn:
    displayName: Recorded On
  file.tags:
    displayName: Tags

views:
  - type: table
    name: Recent
    order:
      - formula.titleLink
      - formula.akteLink
      - formula.recordedOn
      - file.tags
    sort:
      - property: formula.recordedOn
        direction: DESC
