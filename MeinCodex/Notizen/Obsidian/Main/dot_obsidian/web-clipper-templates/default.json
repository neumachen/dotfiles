{
	"schemaVersion": "0.1.0",
	"name": "Default",
	"behavior": "overwrite",
	"noteNameFormat": "{{title|safe_name}}",
	"path": "{{domain|replace:\"/^(?:.*\\.)?([^.]+)\\.[^.]+$/\":\"$1\"}}/{{domain}}",
	"noteContentFormat": "{{content}}",
	"properties": [
		{ "name": "title", "value": "{{title}}", "type": "text" },
		{ "name": "source", "value": "{{url}}", "type": "text" },
		{ "name": "author", "value": "{{author}}", "type": "multitext" },
		{ "name": "published", "value": "{{published}}", "type": "date" },
		{ "name": "created", "value": "{{date|date:\"YYYY-MM-DD\"}}", "type": "date" },
		{ "name": "description", "value": "{{description}}", "type": "text" },
		{ "name": "tags", "value": "clippings", "type": "multitext" },
		{ "name": "modified_at.utc", "value": "{{date|date:\"YYYY-MM-DDTHH:mm:ss\"}}Z", "type": "text" }
	],
	"triggers": []
}
