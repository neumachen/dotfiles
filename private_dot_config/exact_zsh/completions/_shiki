#compdef shiki

_shiki() {
  local context state state_descr line
  typeset -A opt_args

  local idx_docker=${words[(I)--]}
  local after_docker=$(( idx_docker && CURRENT > idx_docker ? 1 : 0 ))

  # If after `--`, delegate to docker run completion.
  #
  # NOTE: The launcher's parse_docker_extras only accepts a narrow subset
  # of `docker run` flags — `-e/--env KEY=VAL` and `-v/--volume HOST:CONT[:MODE]`.
  # Anything else is rejected at runtime with `die`. We still delegate to
  # the full _docker completer because it offers useful value completion
  # for those two flags (volume paths, env var names), and the broader
  # flag list is informational; the launcher gates what actually runs.
  if (( after_docker )); then
    if (( ${+functions[_docker]} )); then
      local -a save_words rest
      local saveCURRENT=$CURRENT

      save_words=("${words[@]}")
      rest=("${words[@]:idx_docker+1}")

      words=(docker run "${rest[@]}")
      CURRENT=$(( saveCURRENT - idx_docker + 2 ))

      _docker

      words=("${save_words[@]}")
      CURRENT=$saveCURRENT
      return
    else
      _message 'shiki accepts only -e/--env KEY=VAL and -v/--volume HOST:CONT[:MODE] after -- (install Docker zsh completion for value hints)'
      return
    fi
  fi


  # Handle additional directory values after -d/--dir.
  # The wrapper keeps consuming non-option words as directories until the next
  # option (anything starting with -) or `--`.
  local i in_dir_list=0
  for (( i = 2; i < CURRENT; i++ )); do
    case ${words[i]} in
      --)
        break
        ;;
      -d|--dir)
        in_dir_list=1
        ;;
      -*)
        in_dir_list=0
        ;;
      *)
        ;;
    esac
  done

  if (( in_dir_list )) && [[ -z ${words[CURRENT]} || ${words[CURRENT]} != -* ]]; then
    _directories
    return
  fi

  # Before `--`: complete wrapper options only
  _arguments -S -s \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '--about[show a short description of Shiki]' \
    '(-n --name)'{-n,--name}'[session/container name]:session name:_shiki_sessions' \
    '(-i --image)'{-i,--image}'[container image to run]:image:_shiki_images' \
    '(-p --port)'{-p,--port}'[host port for AiderDesk UI (default: auto-assigned)]:port:' \
    '*'{-d,--dir}'[project directory to mount (one or more may follow)]:directory:_directories' \
    '(--host-network --bridge-network)--host-network[share the host network namespace so localhost inside shiki is the host]' \
    '(--host-network --bridge-network)--bridge-network[use normal bridge networking (default)]' \
    '--docker-host[bind host Docker socket into the container (DooD; security tradeoff)]' \
    '--aws-share[share host AWS SSO config + Terraform CLI state (read-only)]' \
    '--kube-share[share host ~/.kube (read-only) for kubectl/helm against EKS; implies --aws-share]' \
    '--pull[pull the upstream AiderDesk base image and exit]' \
    '--rebuild=-[rebuild the local shiki image and exit; modifiers: pull,no-pull,cache,no-cache]:modifiers:_shiki_rebuild_modifiers' \
    '--update-extensions[recreate the per-session extensions volume from the current image]' \
    '--[end of wrapper args; start docker run args]'
}

# Session names are sourced from the on-host data dir (~/.local/share/aider-desk/<name>)
# instead of `docker ps`, so both running and removed-but-restorable sessions
# show up. Falls back to `docker ps -a` if the data dir is missing.
_shiki_sessions() {
  local -a sessions
  local data_root="${AIDER_DESK_DATA_ROOT:-$HOME/.local/share/aider-desk}"
  if [[ -d $data_root ]]; then
    # Use zsh glob to list immediate subdirs; portable across macOS/Linux
    # (no GNU-only `find -printf`). `(/N:t)` = dirs only, nullglob, tail name.
    sessions=($data_root/*(/N:t))
  fi
  if (( ${#sessions} == 0 )); then
    sessions=(${(f)"$(docker ps -a --format '{{.Names}}' 2>/dev/null)"})
  fi
  if (( $#sessions )); then
    _describe 'session' sessions
  else
    _message 'session name (leave blank to auto-generate)'
  fi
}

_shiki_images() {
  local -a imgs
  imgs=(${(f)"$(docker image ls --format '{{.Repository}}:{{.Tag}}' 2>/dev/null)"})
  (( $#imgs )) && compadd -- $imgs || _message 'image'
}

# Comma-separable modifiers for --rebuild=<mods>. The launcher parses the
# value with `IFS=',' read`, so this completer offers each token at the
# current comma-separated position. zsh's _values handles the
# comma-separated value list and de-duplicates already-chosen tokens.
_shiki_rebuild_modifiers() {
  _values -s , 'rebuild modifier' \
    'pull[pull the upstream AiderDesk base image before rebuild]' \
    'no-pull[do not pull the upstream image; use whatever is local]' \
    'cache[use the Docker build cache]' \
    'no-cache[do not use the Docker build cache (default)]'
}

_shiki "$@"
