# -*- mode: sh; sh-set-shell: zsh -*-
# vim: ft=zsh

source "${HOME}/.shtils"

# Override the POSIX command_exists from .shtils with the faster zsh-native version
command_exists() { (( $+commands[$1] )); }

# Deduplicate PATH entries - catches anything path_helper or other tools add
typeset -U PATH path

{{ if eq .chezmoi.os "darwin" -}}
# Set BREW_PREFIX once, authoritatively
if [[ -z "${BREW_PREFIX}" ]]; then
  export BREW_PREFIX=$([[ "$(arch)" == "arm64" ]] && echo "/opt/homebrew" || echo "/usr/local")
fi

# Homebrew MANPATH and INFOPATH
manual_pathmunge "${BREW_PREFIX}/share/man"
info_pathmunge "${BREW_PREFIX}/share/info"
manual_pathmunge "${BREW_PREFIX}/opt/coreutils/libexec/gnuman"
manual_pathmunge "${BREW_PREFIX}/opt/make/libexec/gnuman"

# Force-front all Homebrew and GNU override paths.
# path_force_front unconditionally moves an entry to the front of PATH even if
# path_helper or a parent process already injected it at the wrong position.
#
# Calls are in ASCENDING priority order (first call = ends up deepest).
# The LAST call wins position 1 in the final PATH.
#
# Desired final order (left = highest priority / position 1):
#   coreutils → make → m4 → file-formula → unzip → flex → bison → libressl
#   → ed → findutils → gcc → gawk → gnu-indent → gnu-sed → gnu-tar → gnu-which
#   → grep → [ncurses arm64] → /opt/homebrew/bin → /opt/homebrew/sbin → (system)
#
# ~/.local/bin and ~/.local/sbin are handled below with pathmunge after
# and must always appear after all of the above.

# Homebrew bin/sbin first (lowest priority among forced entries — called first)
path_force_front "${BREW_PREFIX}/sbin"
path_force_front "${BREW_PREFIX}/bin"

{{ if eq .chezmoi.arch "arm64" -}}
# ncurses (arm64 only)
[[ -d "${BREW_PREFIX}/opt/ncurses/bin" ]] && path_force_front "${BREW_PREFIX}/opt/ncurses/bin"
{{ end -}}

# GNU grep
[[ -d "${BREW_PREFIX}/opt/grep/libexec/gnubin" ]]       && path_force_front "${BREW_PREFIX}/opt/grep/libexec/gnubin"

# GNU which
[[ -d "${BREW_PREFIX}/opt/gnu-which/libexec/gnubin" ]]  && path_force_front "${BREW_PREFIX}/opt/gnu-which/libexec/gnubin"

# GNU tar
[[ -d "${BREW_PREFIX}/opt/gnu-tar/libexec/gnubin" ]]    && path_force_front "${BREW_PREFIX}/opt/gnu-tar/libexec/gnubin"

# GNU sed
[[ -d "${BREW_PREFIX}/opt/gnu-sed/libexec/gnubin" ]]    && path_force_front "${BREW_PREFIX}/opt/gnu-sed/libexec/gnubin"

# GNU indent
[[ -d "${BREW_PREFIX}/opt/gnu-indent/libexec/gnubin" ]] && path_force_front "${BREW_PREFIX}/opt/gnu-indent/libexec/gnubin"

# GNU awk
[[ -d "${BREW_PREFIX}/opt/gawk/libexec/gnubin" ]]       && path_force_front "${BREW_PREFIX}/opt/gawk/libexec/gnubin"

# gcc
[[ -d "${BREW_PREFIX}/opt/gcc/bin" ]]                   && path_force_front "${BREW_PREFIX}/opt/gcc/bin"

# GNU findutils
[[ -d "${BREW_PREFIX}/opt/findutils/libexec/gnubin" ]]  && path_force_front "${BREW_PREFIX}/opt/findutils/libexec/gnubin"

# GNU ed
[[ -d "${BREW_PREFIX}/opt/ed/libexec/gnubin" ]]         && path_force_front "${BREW_PREFIX}/opt/ed/libexec/gnubin"

# libressl
[[ -d "${BREW_PREFIX}/opt/libressl/bin" ]]              && path_force_front "${BREW_PREFIX}/opt/libressl/bin"

# bison
[[ -d "${BREW_PREFIX}/opt/bison/bin" ]]                 && path_force_front "${BREW_PREFIX}/opt/bison/bin"

# flex
[[ -d "${BREW_PREFIX}/opt/flex/bin" ]]                  && path_force_front "${BREW_PREFIX}/opt/flex/bin"

# unzip
[[ -d "${BREW_PREFIX}/opt/unzip/bin" ]]                 && path_force_front "${BREW_PREFIX}/opt/unzip/bin"

# file-formula
[[ -d "${BREW_PREFIX}/opt/file-formula/bin" ]]          && path_force_front "${BREW_PREFIX}/opt/file-formula/bin"

# GNU m4
[[ -d "${BREW_PREFIX}/opt/m4/bin" ]]                    && path_force_front "${BREW_PREFIX}/opt/m4/bin"

# GNU make
[[ -d "${BREW_PREFIX}/opt/make/libexec/gnubin" ]]       && path_force_front "${BREW_PREFIX}/opt/make/libexec/gnubin"

# GNU coreutils — highest priority, called last so it lands at position 1
[[ -d "${BREW_PREFIX}/opt/coreutils/libexec/gnubin" ]]  && path_force_front "${BREW_PREFIX}/opt/coreutils/libexec/gnubin"

{{ end -}}

if [[ -z "${CHEZMOI_CONFIG_DIR}" ]]; then
  if command_exists chezmoi; then
    export CHEZMOI_CONFIG_DIR="${HOME}/.config/chezmoi"
    [[ -z "${DOTFILES_DIR}" ]] && export DOTFILES_DIR="$(chezmoi source-path)"
  fi
fi

# GPG TTY for signing (required when gpg installed via brew)
[[ -z "${GPG_TTY}" ]] && export GPG_TTY=$(command tty 2>/dev/null)

# Local bin directories - create silently if missing
_local_bin="${HOME}/.local/bin"
[[ ! -d "${_local_bin}" ]] && mkdir -p "${_local_bin}"
export LOCAL_BIN="${_local_bin}"

_local_sbin="${HOME}/.local/sbin"
[[ ! -d "${_local_sbin}" ]] && mkdir -p "${_local_sbin}"
export LOCAL_SBIN="${_local_sbin}"

# fzf bin
_fzf_bin="${HOME}/.local/share/fzf/bin"
if [[ -d "${_fzf_bin}" ]]; then
  pathmunge "${_fzf_bin}" after
fi

# Local bins go after system and Homebrew paths
pathmunge "${LOCAL_BIN}" after
pathmunge "${LOCAL_SBIN}" after

# Taskwarrior config
if [[ ! -d "${XDG_CONFIG_HOME}/taskwarrior" ]] && command_exists task; then
  export TASKWARRIOR_CONFIG="${XDG_CONFIG_HOME}/taskwarrior"
fi

{{- if (hasKey . "envvars") }}
{{ range .envvars }}
export {{ . }}
{{- end -}}
{{ end }}
