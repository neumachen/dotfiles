# ZSH only and most performant way to check existence of an executable
# https://www.topbug.net/blog/2016/10/11/speed-test-check-the-existence-of-a-command-in-bash-and-zsh/
# Override the POSIX version from sh/lib.sh with the faster zsh-specific version
command_exists() { (( $+commands[$1] )); }

#############################
# tmux auto-start (opt-in, attach-or-create)
#############################
#
# Disabled by default. Enable per-host or per-terminal by exporting
# ZSH_TMUX_AUTOSTART=1 (e.g. in dot_zprofile.tmpl, or via Ghostty's
# `command = env ZSH_TMUX_AUTOSTART=1 zsh -l`).
#
# Guards, in order:
#   - interactive shells only (never CI / scripts / `ghostty +validate-config`)
#   - opt-in via ZSH_TMUX_AUTOSTART
#   - tmux must be installed
#   - skip if already inside tmux (no nested sessions)
#   - skip over SSH unless ZSH_TMUX_AUTOSTART_SSH=1 (avoid surprising remote logins)
#   - if ZSH_TMUX_AUTOSTART_GHOSTTY_ONLY=1, only fire inside Ghostty
#
# `exec` replaces this shell with tmux so exiting tmux closes the window
# cleanly. `new-session -A -s <name>` attaches to the session if it exists,
# otherwise creates it.
if [[ -o interactive ]] \
  && [[ "${ZSH_TMUX_AUTOSTART:-0}" == "1" ]] \
  && command_exists tmux \
  && [[ -z "$TMUX" ]]; then
  _zsh_tmux_ok=1
  # Don't hijack SSH logins unless explicitly opted in.
  if [[ -n "${SSH_TTY:-}${SSH_CONNECTION:-}" && "${ZSH_TMUX_AUTOSTART_SSH:-0}" != "1" ]]; then
    _zsh_tmux_ok=0
  fi
  # Optionally restrict auto-start to Ghostty only.
  if [[ "${ZSH_TMUX_AUTOSTART_GHOSTTY_ONLY:-0}" == "1" && -z "${GHOSTTY_RESOURCES_DIR:-}" ]]; then
    _zsh_tmux_ok=0
  fi
  if [[ "$_zsh_tmux_ok" == "1" ]]; then
    unset _zsh_tmux_ok
    exec tmux new-session -A -s "${ZSH_TMUX_AUTOSTART_SESSION:-main}"
  fi
  unset _zsh_tmux_ok
fi

#############################
# zsh-vi-mode Configuration (MUST be before zimfw bootstrap)
# zvm_config() is called by zsh-vi-mode during its own sourcing inside
# init.zsh. With ZVM_INIT_MODE=sourcing the call happens synchronously,
# so this function must be defined before source ${ZIM_HOME}/init.zsh.
#############################

function zvm_config() {
  # Initialize synchronously at sourcing time so zvm wraps ZLE widgets
  # before zsh-autocomplete / fzf-tab layer on top, producing a stable
  # widget chain and avoiding intermittent Tab failures.
  ZVM_INIT_MODE=sourcing

  ZVM_VI_INSERT_ESCAPE_BINDKEY=jk
  ZVM_KEYTIMEOUT=0.15
  ZVM_INSERT_MODE_CURSOR=$ZVM_CURSOR_BEAM
  ZVM_NORMAL_MODE_CURSOR=$ZVM_CURSOR_BLOCK

  # Force every new prompt to start in INSERT mode so Tab and completion
  # keys are always active regardless of what mode a prior TUI left behind.
  ZVM_LINE_INIT_MODE=$ZVM_MODE_INSERT
}

