# Override `open` to use Bloom (refined Finder alternative) for directories
# when installed, falling back to the system `open` (Finder) otherwise.
# Non-directory args (files, URLs, flags) always pass straight through.
function open() {
  local bloom_app="/Applications/Bloom.app"

  if [[ -d "$bloom_app" ]]; then
    local -a dir_args other_args
    for arg in "$@"; do
      if [[ -d "$arg" ]]; then
        dir_args+=("$arg")
      else
        other_args+=("$arg")
      fi
    done
    [[ ${#dir_args[@]} -gt 0 ]] && command open -a Bloom "${dir_args[@]}"
    [[ ${#other_args[@]} -gt 0 ]] && command open "${other_args[@]}"
  else
    command open "$@"
  fi
}

function source-env() {
  if [[ $# -eq 0 ]]; then
    echo "Usage: source-env <file> [file...]" >&2
    return 1
  fi

  for file in "$@"; do
    if [[ ! -f "${file}" ]]; then
      echo-err "the given file : ${file} does not exist"
      return 1
    fi

    source <(cat "${file}" | sed -n -e '/^#/d;/^\s*$/d' \
      -e "s/'/'\\\''/g" \
      -e "s/=\(.*\)/='\1'/g" \
      -e 's/.*/export &/p')
  done
}

function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [[ -n "$cwd" ]] && [[ "$cwd" != "$PWD" ]]; then
    builtin cd -- "$cwd"
  fi
  command rm -f -- "$tmp"
}

function reload-shell() {
  exec zsh -il
}

