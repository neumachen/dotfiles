.tokens

# Python
# ---------------------------------------------------------------------------------------------
venv/

*.pyc
__pycache__/
*.pyo
instance/

.pytest_cache/
.coverage
htmlcov/

dist/
build/
*.egg-info/

tagged

# Go
.cover
**/vendor

# Code mapping / indexing tools
# ---------------------------------------------------------------------------------------------
# Local code-graph / symbol-index databases generated by tooling
# (e.g. codegraph, Serena). Per-repo, machine-local, regenerable from
# source — never commit.
.codegraph/
.serena/
.codemap/

# Terraform / OpenTofu
# ---------------------------------------------------------------------------------------------
# Local state, lock backups, and crash logs must never be committed.
# .terraform.lock.hcl IS committed (per TERRAFORM-01-CORE-STYLE), so it is
# intentionally NOT in this list — only the runtime `.terraform/` directory
# and the state files themselves are ignored.
.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfplan
*.tfplan.binary
crash.log
crash.*.log
# tfvars MAY contain secrets. Default to ignored; users can override
# per-repo with `!*.tfvars` in the project's own .gitignore.
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Aider / AiderDesk
.aider*
.aider-desk/

# .env files
.env
*.env
^env$

# Personal folder of ignored files/directoaries
# ---------------------------------------------------------------------------------------------
.git-ignored/
.gitignored/
_git-ignored/
_gitignored/

# Claude Code local settings
.claude/
**/.claude/settings.local.json

# Codex CLI local config (chezmoi renders the `dot_codex/` source to the
# `~/.codex/` target; a literal `.codex/` in a source tree is accidental
# and must never be tracked).
.codex/
