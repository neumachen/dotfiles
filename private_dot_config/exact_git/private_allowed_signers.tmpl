# Allowed SSH signing keys for Git signature verification
# Format: <email> <key-type> <public-key>

# Default signing key
{{ if .onepassword.ssh_signing_key -}}
{{ .git.email }} {{ .onepassword.ssh_signing_key }}
{{- end }}

# Profile-specific signing keys
{{- if .git.profiles }}
{{ range .git.profiles -}}
{{ if .signingKey -}}
{{ .email }} {{ .signingKey }}
{{ end -}}
{{- end }}
{{- end }}
