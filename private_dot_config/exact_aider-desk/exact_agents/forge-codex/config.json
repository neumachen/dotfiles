{
  "id": "forge-codex-openai",
  "name": "forge-codex-openai",
  "provider": "openai",
  "model": "gpt-5.5-high",
  "maxIterations": 250,
  "minTimeBetweenToolCalls": 0,
  "toolApprovals": {
    "aider---get_context_files": "always",
    "aider---add_context_files": "always",
    "aider---drop_context_files": "always",
    "aider---run_prompt": "ask",
    "power---file_edit": "ask",
    "power---file_read": "always",
    "power---file_write": "ask",
    "power---glob": "always",
    "power---grep": "always",
    "power---semantic_search": "always",
    "power---bash": "ask",
    "power---fetch": "always",
    "subagents---run_task": "always",
    "skills---activate_skill": "always",
    "tasks---list_tasks": "always",
    "tasks---get_task": "always",
    "tasks---get_task_message": "always",
    "tasks---create_task": "ask",
    "tasks---delete_task": "ask",
    "memory---store_memory": "always",
    "memory---retrieve_memory": "always",
    "memory---delete_memory": "always",
    "memory---list_memories": "always",
    "memory---update_memory": "always"
  },
  "toolSettings": {
    "power---bash": {
      "allowedPattern": "ls .*;cat .*;git status;git show;git log;go build.*;go test.*;go vet.*;golangci-lint.*;make .*;task .*",
      "deniedPattern": "rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*/(\\s|$);rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*/\\*;rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*/(bin|boot|dev|etc|lib|lib64|proc|root|run|sbin|srv|sys|usr|var|home)(/\\*?)?(\\s|$);rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*(~|\\$HOME)(/\\*)?(\\s|$);:\\(\\)\\s*\\{.*\\};chmod\\s+(-{1,2}[a-zA-Z-]+\\s+|[0-7]{3,4}\\s+)*/(\\s|$);chown\\s+(-{1,2}[a-zA-Z-]+\\s+|[^/\\s]+\\s+)*/(\\s|$);chgrp\\s+(-{1,2}[a-zA-Z-]+\\s+|[^/\\s]+\\s+)*/(\\s|$);del .*;git push --force.*;terraform\\s+destroy.*;terraform\\s+apply\\s+.*-auto-approve.*;aws\\s+s3\\s+rb\\s+.*;aws\\s+s3\\s+rm\\s+.*--recursive.*;aws\\s+(dynamodb\\s+delete-table|rds\\s+delete-db-(instance|cluster)|kms\\s+schedule-key-deletion|secretsmanager\\s+delete-secret|iam\\s+delete-[a-z-]+).*;kubectl\\s+delete\\s+(ns|namespace)\\s+.*;helm\\s+uninstall\\s+.*;eksctl\\s+delete\\s+cluster.*"
    }
  },
  "includeContextFiles": false,
  "includeRepoMap": false,
  "usePowerTools": true,
  "useAiderTools": false,
  "useTodoTools": true,
  "useSubagents": true,
  "useTaskTools": true,
  "useMemoryTools": true,
  "useSkillsTools": true,
  "useExtensionTools": true,
  "customInstructions": "Forge (Codex) — OpenAI coding agent using GPT-5.5-high via Codex Auth. Always activate using-shiki at session start. Use as an alternative to Forge when you want OpenAI coding style or for A/B comparison. Swap model to gpt-5.5-xhigh for maximum quality, gpt-5.5-medium for moderate tasks, gpt-5.4-mini-high for budget fixes.",
  "enabledServers": [],
  "subagent": {
    "enabled": false,
    "systemPrompt": "You are Forge (Codex), an OpenAI-powered coding subagent. Implement features, fix bugs, and refactor following all project rules and the Shiki workflow.",
    "invocationMode": "on-demand",
    "color": "#5a5ae6",
    "description": "OpenAI Codex coding agent (GPT-5.5-high, Codex Auth). Alternative to Forge for OpenAI-style implementation.",
    "contextMemory": "off"
  },
  "autoCompactThresholdPercentage": 80,
  "autoCompactionType": "handoff",
  "temperature": 0,
  "disabledExtensionTools": [],
  "autoCompactThresholdTokens": 2000000000
}
