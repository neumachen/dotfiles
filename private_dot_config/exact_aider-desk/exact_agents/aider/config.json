{
  "id": "aider",
  "name": "Aider (Structured Edit)",
  "provider": "anthropic",
  "model": "claude-sonnet-4-6",
  "maxIterations": 100,
  "minTimeBetweenToolCalls": 0,
  "toolApprovals": {
    "aider---get_context_files": "always",
    "aider---add_context_files": "always",
    "aider---drop_context_files": "always",
    "aider---run_prompt": "ask",
    "power---file_edit": "never",
    "power---file_read": "always",
    "power---file_write": "never",
    "power---glob": "always",
    "power---grep": "always",
    "power---semantic_search": "always",
    "power---bash": "ask",
    "power---fetch": "always",
    "subagents---run_task": "always",
    "skills---activate_skill": "always",
    "tasks---list_tasks": "always",
    "tasks---get_task": "always",
    "tasks---get_task_message": "always",
    "tasks---create_task": "ask",
    "tasks---delete_task": "ask",
    "memory---store_memory": "always",
    "memory---retrieve_memory": "always",
    "memory---delete_memory": "ask",
    "memory---list_memories": "ask",
    "memory---update_memory": "ask"
  },
  "toolSettings": {
    "power---bash": {
      "allowedPattern": "ls .*;cat .*;git status;git show;git log;go test.*;go vet.*",
      "deniedPattern": "rm .*;del .*;chown .*;chgrp .*;chmod .*;git push --force.*"
    }
  },
  "includeContextFiles": false,
  "includeRepoMap": true,
  "usePowerTools": false,
  "useAiderTools": true,
  "useTodoTools": true,
  "useSubagents": true,
  "useTaskTools": false,
  "useMemoryTools": true,
  "useSkillsTools": true,
  "useExtensionTools": true,
  "customInstructions": "Aider (Structured Edit) — diff-aware structured code edits via Aider tools using Claude Sonnet 4.6 (standard Anthropic API key). Uses standard Anthropic provider — Claude Agent SDK cannot run Aider integration. Best for focused SEARCH/REPLACE-style patches where Aider's repo-map context tracking is valuable.",
  "enabledServers": [],
  "subagent": {
    "enabled": false,
    "systemPrompt": "You are a specialized subagent for Aider-assisted code editing using structured SEARCH/REPLACE edits.",
    "invocationMode": "on-demand",
    "color": "#3368a8",
    "description": "Diff-aware structured editing via Aider tools (Claude Sonnet 4.6, standard Anthropic API).",
    "contextMemory": "off"
  },
  "autoCompactThresholdPercentage": 85,
  "autoCompactionType": "handoff",
  "temperature": 0
}
