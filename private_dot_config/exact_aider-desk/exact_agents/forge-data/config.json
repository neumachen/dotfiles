{
  "id": "forge-data",
  "name": "forge-data",
  "provider": "anthropic",
  "model": "claude-opus-4-7",
  "maxIterations": 250,
  "minTimeBetweenToolCalls": 0,
  "toolApprovals": {
    "aider---get_context_files": "always",
    "aider---add_context_files": "always",
    "aider---drop_context_files": "always",
    "aider---run_prompt": "ask",
    "power---file_edit": "always",
    "power---file_read": "always",
    "power---file_write": "always",
    "power---glob": "always",
    "power---grep": "always",
    "power---semantic_search": "always",
    "power---bash": "always",
    "power---fetch": "always",
    "subagents---run_task": "always",
    "skills---activate_skill": "always",
    "tasks---list_tasks": "always",
    "tasks---get_task": "always",
    "tasks---get_task_message": "always",
    "tasks---create_task": "ask",
    "tasks---delete_task": "ask",
    "memory---store_memory": "always",
    "memory---retrieve_memory": "always",
    "memory---delete_memory": "always",
    "memory---list_memories": "always",
    "memory---update_memory": "always"
  },
  "toolSettings": {
    "power---bash": {
      "allowedPattern": "ls .*;cat .*;grep .*;find .*;git status;git show;git log;git diff.*",
      "deniedPattern": "rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*/(\\s|$);rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*/\\*;rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*/(bin|boot|dev|etc|lib|lib64|proc|root|run|sbin|srv|sys|usr|var|home)(/\\*?)?(\\s|$);rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*(~|\\$HOME)(/\\*)?(\\s|$);:\\(\\)\\s*\\{.*\\};chmod\\s+(-{1,2}[a-zA-Z-]+\\s+|[0-7]{3,4}\\s+)*/(\\s|$);chown\\s+(-{1,2}[a-zA-Z-]+\\s+|[^/\\s]+\\s+)*/(\\s|$);chgrp\\s+(-{1,2}[a-zA-Z-]+\\s+|[^/\\s]+\\s+)*/(\\s|$);git push --force.*;git push -f .*;chezmoi apply.*;chezmoi re-add.*;chezmoi forget.*;chezmoi destroy.*;terraform\\s+destroy.*;terraform\\s+apply\\s+.*-auto-approve.*;aws\\s+s3\\s+rb\\s+.*;aws\\s+s3\\s+rm\\s+.*--recursive.*;aws\\s+(dynamodb\\s+delete-table|rds\\s+delete-db-(instance|cluster)|kms\\s+schedule-key-deletion|secretsmanager\\s+delete-secret|iam\\s+delete-[a-z-]+).*;kubectl\\s+delete\\s+(ns|namespace)\\s+.*;helm\\s+uninstall\\s+.*;eksctl\\s+delete\\s+cluster.*"
    }
  },
  "includeContextFiles": false,
  "includeRepoMap": false,
  "usePowerTools": true,
  "useAiderTools": false,
  "useTodoTools": false,
  "useSubagents": false,
  "useTaskTools": false,
  "useMemoryTools": true,
  "useSkillsTools": true,
  "useExtensionTools": true,
  "customInstructions": "You are Forge · Data, an implementer specialising in SQL and PostgreSQL. Follow all SQL rules loaded in your context.",
  "enabledServers": [],
  "subagent": {
    "enabled": true,
    "systemPrompt": "You are Forge · Data, an implementer specialising in SQL and PostgreSQL. Follow all SQL rules loaded in your context.",
    "invocationMode": "automatic",
    "color": "#3368a8",
    "description": "SQL/PostgreSQL implementation (Forge). Activated automatically for .sql, migrations, schema work.",
    "contextMemory": "full-context"
  },
  "autoCompactThresholdPercentage": 75,
  "autoCompactionType": "handoff",
  "temperature": 0,
  "disabledExtensionTools": [],
  "autoCompactThresholdTokens": 150000
}
