{
  "id": "codex-profile",
  "name": "Codex Profile",
  "provider": "openai",
  "model": "gpt-5-codex",
  "maxIterations": 250,
  "minTimeBetweenToolCalls": 0,
  "toolApprovals": {
    "aider---get_context_files": "always",
    "aider---add_context_files": "always",
    "aider---drop_context_files": "always",
    "aider---run_prompt": "ask",
    "power---file_edit": "ask",
    "power---file_read": "always",
    "power---file_write": "ask",
    "power---glob": "always",
    "power---grep": "always",
    "power---semantic_search": "always",
    "power---bash": "ask",
    "power---fetch": "always",
    "subagents---run_task": "always",
    "skills---activate_skill": "always",
    "tasks---list_tasks": "always",
    "tasks---get_task": "always",
    "tasks---get_task_message": "always",
    "tasks---create_task": "ask",
    "tasks---delete_task": "ask",
    "memory---store_memory": "always",
    "memory---retrieve_memory": "always",
    "memory---delete_memory": "always",
    "memory---list_memories": "always",
    "memory---update_memory": "always"
  },
  "toolSettings": {
    "power---bash": {
      "allowedPattern": "ls .*;cat .*;git status;git show;git log",
      "deniedPattern": "rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*/(\\s|$);rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*/\\*;rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*/(bin|boot|dev|etc|lib|lib64|proc|root|run|sbin|srv|sys|usr|var|home)(/\\*?)?(\\s|$);rm\\s+(-{1,2}[a-zA-Z-]+\\s+)*(~|\\$HOME)(/\\*)?(\\s|$);:\\(\\)\\s*\\{.*\\};chmod\\s+(-{1,2}[a-zA-Z-]+\\s+|[0-7]{3,4}\\s+)*/(\\s|$);chown\\s+(-{1,2}[a-zA-Z-]+\\s+|[^/\\s]+\\s+)*/(\\s|$);chgrp\\s+(-{1,2}[a-zA-Z-]+\\s+|[^/\\s]+\\s+)*/(\\s|$);del .*;terraform\\s+destroy.*;terraform\\s+apply\\s+.*-auto-approve.*;aws\\s+s3\\s+rb\\s+.*;aws\\s+s3\\s+rm\\s+.*--recursive.*;aws\\s+(dynamodb\\s+delete-table|rds\\s+delete-db-(instance|cluster)|kms\\s+schedule-key-deletion|secretsmanager\\s+delete-secret|iam\\s+delete-[a-z-]+).*;kubectl\\s+delete\\s+(ns|namespace)\\s+.*;helm\\s+uninstall\\s+.*;eksctl\\s+delete\\s+cluster.*"
    }
  },
  "includeContextFiles": false,
  "includeRepoMap": false,
  "usePowerTools": true,
  "useAiderTools": false,
  "useTodoTools": true,
  "useSubagents": true,
  "useTaskTools": true,
  "useMemoryTools": true,
  "useSkillsTools": true,
  "useExtensionTools": true,
  "customInstructions": "OpenAI Codex profile: use this when you specifically want Codex-style coding behavior for implementation or comparison against Sonnet. Prefer the Normal Profile for your default day-to-day flow unless Codex is performing better for the task.",
  "enabledServers": [],
  "subagent": {
    "enabled": false,
    "systemPrompt": "",
    "invocationMode": "on-demand",
    "color": "#5a5ae6",
    "description": "",
    "contextMemory": "off"
  },
  "autoCompactThresholdPercentage": 80,
  "autoCompactionType": "handoff",
  "disabledExtensionTools": [],
  "autoCompactThresholdTokens": 2000000000
}
