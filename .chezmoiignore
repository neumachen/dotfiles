# Obsidian vault content — managed at runtime, not by Chezmoi
# Note: akten/, zakki/, kadai/ dirs are created by a chezmoi run-once script.
# Note content is never tracked, but _bases/ subdirectories ARE tracked for Obsidian Bases.
# assets/ is created by Obsidian on first attachment drop; never tracked.
#
# Chezmoi does not support negation patterns, so we explicitly ignore year subdirs
# (where notes live) while allowing _bases/ to pass through.
MeinCodex/Notizen/Obsidian/Main/akten/[0-9]*
MeinCodex/Notizen/Obsidian/Main/zakki/[0-9]*
MeinCodex/Notizen/Obsidian/Main/kadai/[0-9]*
MeinCodex/Notizen/Obsidian/Main/assets/**

# Obsidian plugin compiled/bundled files — downloaded by Obsidian on first launch, not tracked.
# manifest.json (tracked) is sufficient for Obsidian to detect and download missing plugins.
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/plugins/**/main.js
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/plugins/**/styles.css

# Obsidian runtime-generated files inside .obsidian — volatile state written by Obsidian at runtime.
# These are created/updated by Obsidian itself; not configuration we author.
# workspace.json: open-pane layout, rewritten every session
# workspace-mobile.json: mobile layout state
# graph.json: graph view position/filter state
# starred.json: starred files (legacy — Obsidian v1.2+ uses bookmarks.json)
# bookmarks.json: runtime bookmark state
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/workspace.json
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/workspace-mobile.json
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/graph.json
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/starred.json
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/bookmarks.json

# Obsidian plugin runtime/cache files — generated by plugins at runtime, not tracked.
# NOTE: data.json (plugin settings) and manifest.json are still tracked above — only volatile
# cache/index files produced at runtime need to be excluded here.
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/plugins/omnisearch/*.db
MeinCodex/Notizen/Obsidian/Main/dot_obsidian/plugins/omnisearch/*-cache.*

# Codex (~/.codex/) — only config.toml is tracked. Everything below is
# either a credential, machine-specific state, runtime cache, or a database
# Codex rewrites on every launch. Patterns are target paths (relative to $HOME).
.codex/auth.json
.codex/installation_id
.codex/history.jsonl
.codex/models_cache.json
.codex/logs_*.sqlite*
.codex/state_*.sqlite*
.codex/.personality_migration
.codex/.tmp
.codex/cache
.codex/log
.codex/memories
.codex/sessions
.codex/shell_snapshots
.codex/skills

